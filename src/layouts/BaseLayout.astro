---
import '../styles/global.css';
import BackToTop from '../components/BackToTop.astro';
import AnalyticsConsent from '../components/AnalyticsConsent.astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "Envoyou — Publishing Intelligence, Redefined",
  description = "Envoyou combines publishing, editorial workflows, and intelligent content tools into a connected ecosystem designed to move ideas from draft to publication.",
  ogImage = "/og-image.png",
  structuredData = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://www.envoyou.com");
const ogImageURL = new URL(ogImage, Astro.site ?? "https://www.envoyou.com");

const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const pageStructuredData = Array.isArray(structuredData) ? structuredData : [structuredData];
const structuredDataGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://www.envoyou.com/#organization",
      name: "Envoyou",
      url: "https://www.envoyou.com/",
      logo: "https://www.envoyou.com/favicon.svg",
      sameAs: [
        "https://github.com/Envoyou",
        "https://www.linkedin.com/in/husni-kusuma",
        "https://x.com/EnvoyouAPI",
      ],
    },
    {
      "@type": "WebSite",
      "@id": "https://www.envoyou.com/#website",
      url: "https://www.envoyou.com/",
      name: "Envoyou",
      publisher: {
        "@id": "https://www.envoyou.com/#organization",
      },
      inLanguage: "en",
    },
    ...pageStructuredData,
  ],
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f8fafc" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#020617" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredDataGraph)}></script>

    <!-- Inter Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300..900;1,14..32,300..900&display=swap"
      rel="stylesheet"
    />

    <!-- Theme script (prevent flash) -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = stored ?? (prefersDark ? "dark" : "light");
        document.documentElement.classList.toggle("dark", theme === "dark");
      })();
    </script>

    {gaMeasurementId && (
      <script is:inline define:vars={{ gaMeasurementId }}>
        window.dataLayer = window.dataLayer || [];
        window.envoyouAnalyticsGranted = false;
        window.gtag = function(){window.dataLayer.push(arguments);}
        window.gtag('consent', 'default', {
          analytics_storage: 'denied',
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied'
        });

        window.enableEnvoyouAnalytics = function() {
          if (window.envoyouAnalyticsGranted) return;
          window.envoyouAnalyticsGranted = true;
          window.gtag('consent', 'update', { analytics_storage: 'granted' });

          if (!document.querySelector('script[data-envoyou-ga]')) {
            var gaScript = document.createElement('script');
            gaScript.async = true;
            gaScript.src = 'https://www.googletagmanager.com/gtag/js?id=' + encodeURIComponent(gaMeasurementId);
            gaScript.dataset.envoyouGa = 'true';
            gaScript.onload = function() {
              window.gtag('js', new Date());
              window.gtag('config', gaMeasurementId);
            };
            document.head.appendChild(gaScript);
          }
        };

        window.disableEnvoyouAnalytics = function() {
          window.envoyouAnalyticsGranted = false;
          window.gtag('consent', 'update', { analytics_storage: 'denied' });
        };

        window.addEventListener('envoyou:analytics-consent', function(event) {
          if (event.detail === 'granted') {
            window.enableEnvoyouAnalytics();
          } else {
            window.disableEnvoyouAnalytics();
          }
        });

        try {
          if (localStorage.getItem('envoyou_analytics_consent') === 'granted') {
            window.enableEnvoyouAnalytics();
          }
        } catch {
          // Analytics remains disabled when the preference cannot be read.
        }
      </script>
    )}
  </head>
  <body class="bg-bg text-text font-sans antialiased transition-colors duration-300">
    <slot />
    <BackToTop />
    <AnalyticsConsent />
    <script async src="https://tally.so/widgets/embed.js"></script>
    <script>
      type AnalyticsWindow = Window & {
        gtag?: (...args: unknown[]) => void;
        envoyouAnalyticsGranted?: boolean;
      };

      document.addEventListener("click", (clickEvent) => {
        const eventTarget = clickEvent.target;
        if (!(eventTarget instanceof Element)) return;

        const trackedElement = eventTarget.closest<HTMLElement>("[data-analytics-event]");
        if (!trackedElement) return;

        const eventName = trackedElement.dataset.analyticsEvent;
        if (!eventName) return;

        const analyticsWindow = window as AnalyticsWindow;
        if (!analyticsWindow.envoyouAnalyticsGranted) return;

        const properties: Record<string, string> = {
          cta_location: trackedElement.dataset.analyticsLocation ?? "unknown",
        };

        if (trackedElement.dataset.analyticsPlan) {
          properties.plan = trackedElement.dataset.analyticsPlan;
        }

        if (trackedElement.dataset.analyticsBillingCycle) {
          properties.billing_cycle = trackedElement.dataset.analyticsBillingCycle;
        }

        if (trackedElement instanceof HTMLAnchorElement) {
          properties.destination_host = new URL(trackedElement.href, window.location.href).host;
        }

        if (eventName === "beta_access_clicked") {
          try {
            sessionStorage.setItem("envoyou_last_beta_cta", properties.cta_location);
          } catch {
            // Attribution remains optional when session storage is unavailable.
          }
        }

        analyticsWindow.gtag?.("event", eventName, properties);
      });

      // Tally embeds use postMessage for lifecycle events. Only the event name
      // and public form ID are read; submission answers are never accessed.
      window.addEventListener("message", (messageEvent) => {
        const analyticsWindow = window as AnalyticsWindow;
        if (!analyticsWindow.envoyouAnalyticsGranted) return;
        if (messageEvent.origin !== "https://tally.so" || typeof messageEvent.data !== "string") return;
        if (!messageEvent.data.includes("Tally.FormLoaded") && !messageEvent.data.includes("Tally.FormSubmitted")) return;

        try {
          const tallyEvent = JSON.parse(messageEvent.data);
          if (tallyEvent?.payload?.formId !== "ODy5xM") return;

          let ctaLocation = "unknown";
          try {
            ctaLocation = sessionStorage.getItem("envoyou_last_beta_cta") ?? "unknown";
          } catch {
            // Attribution remains optional when session storage is unavailable.
          }

          const eventName = messageEvent.data.includes("Tally.FormSubmitted")
            ? "tally_form_submitted"
            : "tally_form_opened";

          analyticsWindow.gtag?.("event", eventName, {
            form_id: "ODy5xM",
            cta_location: ctaLocation,
          });
        } catch {
          // Ignore unrelated or malformed postMessage payloads.
        }
      });
    </script>
  </body>
</html>
