---
import '../styles/global.css';
import BackToTop from '../components/BackToTop.astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "Envoyou — Publishing Intelligence, Redefined",
  description = "Envoyou combines publishing, editorial workflows, and intelligent content tools into a connected ecosystem designed to move ideas from draft to publication.",
  ogImage = "/og-image.png",
  structuredData = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://envoyou.com");
const ogImageURL = new URL(ogImage, Astro.site ?? "https://envoyou.com");

const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const pageStructuredData = Array.isArray(structuredData) ? structuredData : [structuredData];
const structuredDataGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://envoyou.com/#organization",
      name: "Envoyou",
      url: "https://envoyou.com/",
      logo: "https://envoyou.com/favicon.svg",
      sameAs: [
        "https://github.com/Envoyou",
        "https://www.linkedin.com/in/husni-kusuma",
        "https://x.com/EnvoyouAPI",
      ],
    },
    {
      "@type": "WebSite",
      "@id": "https://envoyou.com/#website",
      url: "https://envoyou.com/",
      name: "Envoyou",
      publisher: {
        "@id": "https://envoyou.com/#organization",
      },
      inLanguage: "en",
    },
    ...pageStructuredData,
  ],
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f8fafc" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#020617" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredDataGraph)}></script>

    <!-- Inter Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300..900;1,14..32,300..900&display=swap"
      rel="stylesheet"
    />

    <!-- Theme script (prevent flash) -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = stored ?? (prefersDark ? "dark" : "light");
        document.documentElement.classList.toggle("dark", theme === "dark");
      })();
    </script>

    {gaMeasurementId && (
      <>
        <!-- Google tag (gtag.js) -->
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
        <script is:inline define:vars={{ gaMeasurementId }}>
          window.dataLayer = window.dataLayer || [];
          window.gtag = function(){window.dataLayer.push(arguments);}
          window.gtag('js', new Date());
          window.gtag('config', gaMeasurementId);
        </script>
      </>
    )}
  </head>
  <body class="bg-bg text-text font-sans antialiased transition-colors duration-300">
    <slot />
    <BackToTop />
    <script async src="https://tally.so/widgets/embed.js"></script>
    <script>
      type AnalyticsWindow = Window & {
        gtag?: (command: string, eventName: string, properties?: Record<string, string>) => void;
      };

      document.addEventListener("click", (clickEvent) => {
        const eventTarget = clickEvent.target;
        if (!(eventTarget instanceof Element)) return;

        const trackedElement = eventTarget.closest<HTMLElement>("[data-analytics-event]");
        if (!trackedElement) return;

        const eventName = trackedElement.dataset.analyticsEvent;
        if (!eventName) return;

        const properties: Record<string, string> = {
          cta_location: trackedElement.dataset.analyticsLocation ?? "unknown",
        };

        if (trackedElement.dataset.analyticsPlan) {
          properties.plan = trackedElement.dataset.analyticsPlan;
        }

        if (trackedElement.dataset.analyticsBillingCycle) {
          properties.billing_cycle = trackedElement.dataset.analyticsBillingCycle;
        }

        if (trackedElement instanceof HTMLAnchorElement) {
          properties.destination_host = new URL(trackedElement.href, window.location.href).host;
        }

        (window as AnalyticsWindow).gtag?.("event", eventName, properties);
      });
    </script>
  </body>
</html>
