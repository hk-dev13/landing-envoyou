---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Products from '../components/sections/Products.astro';
import EcosystemPreview from '../components/sections/EcosystemPreview.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import Faq from '../components/sections/Faq.astro';
import DecisionSections from '../components/sections/DecisionSections.astro';
import ConversionSections from '../components/sections/ConversionSections.astro';
import FinalCta from '../components/sections/FinalCta.astro';

const homepageStructuredData = {
  "@type": "SoftwareApplication",
  "@id": "https://www.envoyou.com/#eai",
  name: "Envoyou AI Editorial Intelligence",
  alternateName: "EAI",
  applicationCategory: "BusinessApplication",
  applicationSubCategory: "Editorial workflow software",
  operatingSystem: "Web",
  url: "https://eai.envoyou.com/login",
  description: "An editorial intelligence workspace for draft refinement, source-sensitive quality review, SEO preparation, and controlled CMS draft export.",
  featureList: [
    "Tenant-aware editorial profiles",
    "Draft refinement and targeted fixes",
    "Final Quality Gate readiness verdict",
    "SEO publication package",
    "Editorial history and analytics",
    "Configured CMS draft export",
  ],
  publisher: {
    "@id": "https://www.envoyou.com/#organization",
  },
};
---

<BaseLayout
  title="EAI Editorial Intelligence for Publishers — Envoyou"
  description="Turn raw drafts into publication-ready articles with controlled refinement, source-sensitive Quality Gate review, SEO preparation, and CMS draft export."
  structuredData={homepageStructuredData}
>
  <Navbar />
  <main id="main-content">
    <Hero />
    <EcosystemPreview />
    <Products />
    <DecisionSections />
    <HowItWorks />
    <ConversionSections />
    <Faq />
    <FinalCta />
  </main>
  <Footer />
</BaseLayout>
