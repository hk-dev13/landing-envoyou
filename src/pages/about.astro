<script>
  // Interactive EAI Workflow Step switching
  const tabs = document.querySelectorAll(".workflow-tab");
  const panels = document.querySelectorAll(".workflow-panel");

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const targetStep = tab.getAttribute("data-step");

      // Update tab active classes
      tabs.forEach((t) => {
        t.classList.remove(
          "active",
          "border-primary",
          "bg-primary/5",
          "dark:bg-primary/10",
        );
        t.classList.add("border-transparent", "hover:bg-surface-soft");

        const numBox = t.querySelector("div");
        if (numBox) {
          numBox.classList.remove(
            "bg-primary/10",
            "text-primary",
            "border-primary/20",
          );
          numBox.classList.add(
            "bg-surface-soft",
            "text-muted",
            "border-border",
          );
        }
      });

      tab.classList.add(
        "active",
        "border-primary",
        "bg-primary/5",
        "dark:bg-primary/10",
      );
      tab.classList.remove("border-transparent", "hover:bg-surface-soft");

      const activeNumBox = tab.querySelector("div");
      if (activeNumBox) {
        activeNumBox.classList.remove(
          "bg-surface-soft",
          "text-muted",
          "border-border",
        );
        activeNumBox.classList.add(
          "bg-primary/10",
          "text-primary",
          "border-primary/20",
        );
      }

      // Update panel visibility with fade effect
      panels.forEach((panel) => {
        if (panel.getAttribute("data-step") === targetStep) {
          panel.classList.remove("hidden");
          panel.classList.add("flex");
        } else {
          panel.classList.add("hidden");
          panel.classList.remove("flex");
        }
      });
    });
  });
</script>
