---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="About Envoyou — The Editorial Intelligence Ecosystem"
  description="Learn about Envoyou's vision to unify keyword research, SERP outline building, contextual AI drafting, quality checking, and CMS exports into one seamless workflow."
>
  <Navbar />

  <main
    class="min-h-screen bg-bg pt-24 pb-20 relative overflow-hidden transition-colors duration-300"
  >
    <!-- Ambient Radial Glows -->
    <div
      class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_25%_0%,var(--color-hero-glow)_0%,transparent_45%),radial-gradient(circle_at_75%_10%,var(--color-hero-glow-2)_0%,transparent_40%)]"
    >
    </div>

    <!-- ── Hero Section ── -->
    <section
      class="max-w-[90rem] mx-auto px-6 pt-16 pb-20 text-center relative"
    >
      <div class="section-label mx-auto">Our Vision</div>
      <h1
        class="text-4xl sm:text-6xl font-black tracking-tight text-text max-w-4xl mx-auto leading-tight"
      >
        We Don't Just Help You Write.<br />
        <span class="text-primary">We Help You Finish.</span>
      </h1>
      <p
        class="section-subtitle mx-auto text-center mt-6 text-lg max-w-2xl text-muted leading-relaxed"
      >
        Envoyou is a unified Editorial Intelligence platform designed to take
        SEO-ready content from initial research to published article—in a
        single, uninterrupted workflow.
      </p>

      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a
          href="https://eai.envoyou.com"
          target="_blank"
          rel="noopener noreferrer"
          data-analytics-event="eai_outbound_clicked"
          data-analytics-location="about_hero"
          class="btn-primary"
        >
          Try EAI Workspace
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
          </svg>
        </a>
        <a href="/#products" class="btn-secondary"> Explore Products </a>
      </div>
    </section>

    <!-- ── The Fragmented Problem ── -->
    <section class="max-w-6xl mx-auto px-6 py-20 border-t border-border/60">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
        <div class="lg:col-span-5">
          <span
            class="text-xs font-bold uppercase tracking-widest text-red-500 bg-red-500/10 px-3 py-1 rounded-full border border-red-500/20 mb-4 inline-block"
          >
            The Status Quo
          </span>
          <h2
            class="text-3xl sm:text-4xl font-extrabold text-text tracking-tight leading-tight"
          >
            The Content Fragmentation Tax
          </h2>
          <p class="text-muted mt-4 leading-relaxed text-sm sm:text-base">
            Crafting search-optimized, high-integrity articles isn't a
            single-step job. Today's editorial operations are broken across half
            a dozen single-purpose tools, causing friction and quality leaks.
          </p>
          <p class="text-muted mt-3 leading-relaxed text-sm sm:text-base">
            Writers spend more energy shuffling text, manually reviewing
            formatting, and wrestling with SEO plug-ins than focusing on
            creative strategy. The problem isn't a lack of tools. It's the
            absence of a unified system.
          </p>
        </div>

        <div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div class="card p-6 relative group">
            <div
              class="w-10 h-10 rounded-xl bg-red-500/10 border border-red-500/20 flex items-center justify-center text-red-500 mb-4 group-hover:scale-105 transition-transform"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                ></path>
              </svg>
            </div>
            <h3 class="font-bold text-text text-base">
              4 to 6 Fragmented Tools
            </h3>
            <p class="text-xs text-muted mt-2 leading-relaxed">
              Toggling between keyword planners, SERP outline scrapers, draft
              editors, optimization scorecards, and CMS publishing interfaces.
            </p>
          </div>

          <div class="card p-6 relative group">
            <div
              class="w-10 h-10 rounded-xl bg-red-500/10 border border-red-500/20 flex items-center justify-center text-red-500 mb-4 group-hover:scale-105 transition-transform"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                ></path>
              </svg>
            </div>
            <h3 class="font-bold text-text text-base">Chore Work Fatigue</h3>
            <p class="text-xs text-muted mt-2 leading-relaxed">
              Spending excessive time on copy-pasting, heading alignment, manual
              internal linking, and meta tag verification.
            </p>
          </div>

          <div class="card p-6 relative group">
            <div
              class="w-10 h-10 rounded-xl bg-red-500/10 border border-red-500/20 flex items-center justify-center text-red-500 mb-4 group-hover:scale-105 transition-transform"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <h3 class="font-bold text-text text-base">
              Generic AI Hallucinations
            </h3>
            <p class="text-xs text-muted mt-2 leading-relaxed">
              Standard AI writer tools pull from stale datasets, generating
              repetitive, untrustworthy drafts that require heavy rewriting.
            </p>
          </div>

          <div class="card p-6 relative group">
            <div
              class="w-10 h-10 rounded-xl bg-red-500/10 border border-red-500/20 flex items-center justify-center text-red-500 mb-4 group-hover:scale-105 transition-transform"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </div>
            <h3 class="font-bold text-text text-base">
              Publish Delay & Errors
            </h3>
            <p class="text-xs text-muted mt-2 leading-relaxed">
              Broken styles, unoptimized assets, or missing keywords during
              manual copy-paste transitions into a CMS.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── EAI Interactive Workflow Section ── -->
    <section
      class="max-w-[90rem] mx-auto px-6 py-20 border-t border-border/60 bg-surface-soft/40 relative"
    >
      <div
        class="absolute inset-0 bg-radial-[circle_at_center] from-primary/5 to-transparent pointer-events-none"
      >
      </div>

      <div class="max-w-4xl mx-auto text-center mb-16 relative">
        <div class="section-label mx-auto">The Integrated Workspace</div>
        <h2
          class="text-3xl sm:text-4xl font-extrabold text-text tracking-tight"
        >
          EAI Editorial Intelligence in Action
        </h2>
        <p
          class="text-muted mt-4 text-sm sm:text-base max-w-xl mx-auto leading-relaxed"
        >
          See how EAI resolves the fragmentation tax by consolidating keyword
          research, layout structuring, grounded generation, formatting, and
          sync in a single workspace loop.
        </p>
      </div>

      <!-- Interactive Tab & Panel Layout -->
      <div
        class="grid grid-cols-1 lg:grid-cols-12 gap-12 max-w-6xl mx-auto relative items-stretch"
      >
        <!-- Left Side: Interactive Step Selectors -->
        <div class="lg:col-span-5 flex flex-col gap-4 justify-center">
          <!-- Step 1 Tab -->
          <button
            class="workflow-tab active w-full text-left p-5 rounded-2xl border border-primary bg-primary/5 dark:bg-primary/10 transition-all duration-300 cursor-pointer flex gap-4 items-start focus:outline-none"
            data-step="1"
          >
            <div
              class="w-8 h-8 rounded-lg bg-primary/10 text-primary border border-primary/20 flex items-center justify-center font-bold font-mono text-sm shrink-0 mt-0.5"
            >
              01
            </div>
            <div>
              <h3 class="font-bold text-text text-base leading-snug">
                AI Drafting Assistant
              </h3>
              <p class="text-xs text-muted mt-1 leading-relaxed">
                Create a structured rough draft from a topic, outline,
                references, or press release.
              </p>
            </div>
          </button>

          <!-- Step 2 Tab -->
          <button
            class="workflow-tab w-full text-left p-5 rounded-2xl border border-transparent hover:bg-surface transition-all duration-300 cursor-pointer flex gap-4 items-start focus:outline-none"
            data-step="2"
          >
            <div
              class="w-8 h-8 rounded-lg bg-surface-soft text-muted border border-border flex items-center justify-center font-bold font-mono text-sm shrink-0 mt-0.5"
            >
              02
            </div>
            <div>
              <h3 class="font-bold text-text text-base leading-snug">
                Multi-Stage Editorial Polish
              </h3>
              <p class="text-xs text-muted mt-1 leading-relaxed">
                Stream a polished rewrite matching your custom target voice,
                category, and audience.
              </p>
            </div>
          </button>

          <!-- Step 3 Tab -->
          <button
            class="workflow-tab w-full text-left p-5 rounded-2xl border border-transparent hover:bg-surface transition-all duration-300 cursor-pointer flex gap-4 items-start focus:outline-none"
            data-step="3"
          >
            <div
              class="w-8 h-8 rounded-lg bg-surface-soft text-muted border border-border flex items-center justify-center font-bold font-mono text-sm shrink-0 mt-0.5"
            >
              03
            </div>
            <div>
              <h3 class="font-bold text-text text-base leading-snug">
                Quality Gate & Fact Verification
              </h3>
              <p class="text-xs text-muted mt-1 leading-relaxed">
                Audit draft against reference files for factual accuracy,
                temporal consistency, and formatting.
              </p>
            </div>
          </button>

          <!-- Step 4 Tab -->
          <button
            class="workflow-tab w-full text-left p-5 rounded-2xl border border-transparent hover:bg-surface transition-all duration-300 cursor-pointer flex gap-4 items-start focus:outline-none"
            data-step="4"
          >
            <div
              class="w-8 h-8 rounded-lg bg-surface-soft text-muted border border-border flex items-center justify-center font-bold font-mono text-sm shrink-0 mt-0.5"
            >
              04
            </div>
            <div>
              <h3 class="font-bold text-text text-base leading-snug">
                SEO Pack Generation
              </h3>
              <p class="text-xs text-muted mt-1 leading-relaxed">
                Automatically structure search titles, optimized slugs, tags,
                and meta descriptions.
              </p>
            </div>
          </button>

          <!-- Step 5 Tab -->
          <button
            class="workflow-tab w-full text-left p-5 rounded-2xl border border-transparent hover:bg-surface transition-all duration-300 cursor-pointer flex gap-4 items-start focus:outline-none"
            data-step="5"
          >
            <div
              class="w-8 h-8 rounded-lg bg-surface-soft text-muted border border-border flex items-center justify-center font-bold font-mono text-sm shrink-0 mt-0.5"
            >
              05
            </div>
            <div>
              <h3 class="font-bold text-text text-base leading-snug">
                One-Click CMS Export
              </h3>
              <p class="text-xs text-muted mt-1 leading-relaxed">
                Prepare clean markup, cover guidance, and SEO metadata for
                controlled export to a configured CMS draft.
              </p>
            </div>
          </button>
        </div>

        <!-- Right Side: Interactive Mockup Screens -->
        <div class="lg:col-span-7 flex items-center">
          <div
            class="w-full relative card bg-surface p-6 sm:p-8 min-h-[460px] flex flex-col justify-between overflow-hidden border border-border shadow-xl"
          >
            <div
              class="absolute inset-0 rounded-[var(--radius-lg)] pointer-events-none"
              style="background: radial-gradient(circle at 80% 10%, var(--color-hero-glow) 0%, transparent 60%);"
            >
            </div>

            <!-- Panel 1: Drafting Assistant -->
            <div
              class="workflow-panel flex flex-col h-full justify-between gap-6"
              data-step="1"
            >
              <div>
                <div
                  class="flex items-center justify-between border-b border-border pb-4 mb-4"
                >
                  <div class="flex items-center gap-2">
                    <span
                      class="w-2.5 h-2.5 rounded-full bg-primary animate-pulse"
                    ></span>
                    <span
                      class="text-xs font-mono font-semibold uppercase tracking-wider text-muted"
                      >AI Drafting Assistant</span
                    >
                  </div>
                  <span
                    class="text-[10px] font-bold bg-primary/10 border border-primary/20 text-primary px-2.5 py-0.5 rounded-full"
                    >Assistant Active</span
                  >
                </div>

                <div class="space-y-4">
                  <div
                    class="ui-segmented grid grid-cols-4 bg-surface-soft p-1 rounded-xl gap-1"
                  >
                    <span
                      class="text-[10px] font-semibold bg-surface text-primary border border-border rounded-lg py-1 px-2 text-center shadow-sm"
                      >From Topic</span
                    >
                    <span class="text-[10px] text-muted py-1 px-2 text-center"
                      >From Outline</span
                    >
                    <span class="text-[10px] text-muted py-1 px-2 text-center"
                      >References</span
                    >
                    <span class="text-[10px] text-muted py-1 px-2 text-center"
                      >Press Release</span
                    >
                  </div>

                  <div class="space-y-2">
                    <label
                      class="text-[10px] font-bold uppercase tracking-wider text-muted block"
                      >Topic / Core Idea</label
                    >
                    <div
                      class="bg-surface-soft border border-border rounded-xl px-4 py-3 text-xs text-text font-medium leading-relaxed"
                    >
                      The impact of Nvidia Blackwell GPUs on Southeast Asia's
                      cloud capacity
                    </div>
                  </div>

                  <div class="space-y-2">
                    <label
                      class="text-[10px] font-bold uppercase tracking-wider text-muted flex items-center justify-between"
                    >
                      <span>Import References (URL Scraper)</span>
                      <span class="text-emerald-500 font-semibold lowercase"
                        >Clean text extractor</span
                      >
                    </label>
                    <div class="flex gap-2">
                      <div
                        class="flex-1 bg-surface-soft border border-border rounded-xl px-3 py-2 text-xs text-muted truncate flex items-center gap-2"
                      >
                        https://nvidianews.nvidia.com/news/blackwell-gpus...
                      </div>
                      <button
                        class="bg-surface border border-border text-text px-3.5 rounded-xl text-[10px] font-bold shrink-0"
                        >Fetched</button
                      >
                    </div>
                  </div>
                </div>
              </div>

              <div>
                <button
                  class="w-full bg-primary hover:bg-primary-deep text-on-primary text-xs font-semibold py-2.5 rounded-xl transition-colors flex items-center justify-center gap-2 shadow-sm"
                >
                  <svg
                    class="w-3.5 h-3.5 animate-spin"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    viewBox="0 0 24 24"
                    style="animation-duration: 3s;"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M9.813 15.904L9 21l8.904-4.473L21 9l-3.473-3.473L9.813 15.904zM9.813 15.904L9 21l3.473-3.473m0-12L15.904 9"
                    ></path>
                  </svg>
                  Generate Rough Draft
                </button>
              </div>
            </div>

            <!-- Panel 2: Polish -->
            <div
              class="workflow-panel hidden flex flex-col h-full justify-between gap-6"
              data-step="2"
            >
              <div>
                <div
                  class="flex items-center justify-between border-b border-border pb-4 mb-4"
                >
                  <div class="flex items-center gap-2">
                    <span
                      class="w-2.5 h-2.5 rounded-full bg-primary animate-pulse"
                    ></span>
                    <span
                      class="text-xs font-mono font-semibold uppercase tracking-wider text-muted"
                      >Single-Click Editorial Polish</span
                    >
                  </div>
                  <span
                    class="text-[10px] font-bold bg-emerald-500/10 border border-emerald-500/20 text-emerald-500 px-2.5 py-0.5 rounded-full"
                    >Draft Refining..</span
                  >
                </div>

                <div class="space-y-4">
                  <div class="grid grid-cols-3 gap-2">
                    <div
                      class="bg-surface-soft border border-border rounded-xl p-2.5 text-center"
                    >
                      <p class="text-[9px] font-mono text-muted uppercase">
                        Category
                      </p>
                      <p class="text-xs font-bold text-text mt-0.5 truncate">
                        Technology & AI
                      </p>
                    </div>
                    <div
                      class="bg-surface-soft border border-border rounded-xl p-2.5 text-center"
                    >
                      <p class="text-[9px] font-mono text-muted uppercase">
                        Type
                      </p>
                      <p class="text-xs font-bold text-text mt-0.5 truncate">
                        Analysis
                      </p>
                    </div>
                    <div
                      class="bg-surface-soft border border-border rounded-xl p-2.5 text-center"
                    >
                      <p class="text-[9px] font-mono text-muted uppercase">
                        Audience
                      </p>
                      <p class="text-xs font-bold text-text mt-0.5 truncate">
                        Tech Leaders
                      </p>
                    </div>
                  </div>

                  <div
                    class="bg-surface-soft border border-border rounded-xl p-4 font-mono text-[11px] leading-relaxed text-text select-none min-h-[140px]"
                  >
                    <p class="text-primary mb-1">
                      &lt;!-- Stage 2: Rewriting & Polishing Output --&gt;
                    </p>
                    <span class="animate-pulse">|</span>Unlike standard AI
                    generators that return cookie-cutter summaries, Envoyou's
                    EAI engine processes the draft under a staged rewrite
                    pipeline. This transforms technical specifications into a
                    narrative that aligns directly with your selected brand
                    profile parameters...
                  </div>
                </div>
              </div>

              <div
                class="flex items-center justify-between text-xs text-muted border-t border-border pt-4"
              >
                <span>Mode: Publish Ready</span>
                <span class="font-bold text-primary">Ctrl+Enter to Refine</span>
              </div>
            </div>

            <!-- Panel 3: Quality Gate -->
            <div
              class="workflow-panel hidden flex flex-col h-full justify-between gap-6"
              data-step="3"
            >
              <div>
                <div
                  class="flex items-center justify-between border-b border-border pb-4 mb-4"
                >
                  <div class="flex items-center gap-2">
                    <span
                      class="w-2.5 h-2.5 rounded-full bg-primary animate-pulse"
                    ></span>
                    <span
                      class="text-xs font-mono font-semibold uppercase tracking-wider text-muted"
                      >Quality Gate & Source Fidelity</span
                    >
                  </div>
                  <span
                    class="text-[10px] font-bold bg-amber-500/10 border border-amber-500/20 text-amber-500 px-2.5 py-0.5 rounded-full"
                    >Audit Active</span
                  >
                </div>

                <div
                  class="flex items-center gap-6 bg-surface-soft/60 border border-border p-4 rounded-xl mb-4"
                >
                  <!-- Circular Progress SVG -->
                  <div
                    class="relative w-16 h-16 shrink-0 flex items-center justify-center"
                  >
                    <svg class="w-full h-full transform -rotate-90">
                      <circle
                        cx="32"
                        cy="32"
                        r="28"
                        class="stroke-border"
                        stroke-width="5"
                        fill="transparent"></circle>
                      <circle
                        cx="32"
                        cy="32"
                        r="28"
                        class="stroke-primary"
                        stroke-width="5"
                        fill="transparent"
                        stroke-dasharray="175"
                        stroke-dashoffset="14"></circle>
                    </svg>
                    <span class="absolute text-sm font-extrabold text-text"
                      >92%</span
                    >
                  </div>
                  <div>
                    <h4 class="font-bold text-text text-sm">
                      Fidelity Readiness Score
                    </h4>
                    <p class="text-xs text-muted mt-0.5">
                      Your draft satisfies all platform accuracy and brand voice
                      checks.
                    </p>
                  </div>
                </div>

                <div class="space-y-2">
                  <div class="flex items-center gap-2.5 text-xs text-text">
                    <svg
                      class="w-4 h-4 text-emerald-500 shrink-0"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span
                      >Factual claims verified against reference sources</span
                    >
                  </div>
                  <div class="flex items-center gap-2.5 text-xs text-text">
                    <svg
                      class="w-4 h-4 text-emerald-500 shrink-0"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span
                      >No hallucination or temporal framing risks flagged</span
                    >
                  </div>
                  <div class="flex items-center gap-2.5 text-xs text-text">
                    <svg
                      class="w-4 h-4 text-amber-500 shrink-0"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                      ></path>
                    </svg>
                    <span
                      >Formatting: Meta description is 165/160 chars (slightly
                      long)</span
                    >
                  </div>
                </div>
              </div>

              <div class="flex gap-2">
                <button
                  class="flex-1 bg-surface border border-border hover:bg-surface-soft text-text text-xs font-semibold py-2 rounded-xl transition-colors"
                  >Reanalyze</button
                >
                <button
                  class="flex-1 bg-primary hover:bg-primary-deep text-on-primary text-xs font-semibold py-2 rounded-xl transition-colors"
                  >Approve Draft</button
                >
              </div>
            </div>

            <!-- Panel 4: SEO Pack -->
            <div
              class="workflow-panel hidden flex flex-col h-full justify-between gap-6"
              data-step="4"
            >
              <div>
                <div
                  class="flex items-center justify-between border-b border-border pb-4 mb-4"
                >
                  <div class="flex items-center gap-2">
                    <span
                      class="w-2.5 h-2.5 rounded-full bg-primary animate-pulse"
                    ></span>
                    <span
                      class="text-xs font-mono font-semibold uppercase tracking-wider text-muted"
