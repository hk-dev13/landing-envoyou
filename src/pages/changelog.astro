---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { ChevronDown } from 'lucide-astro';

const allEntries = await getCollection('changelog');
// Sort by publishDate descending, then by version descending if dates are equal
const sortedEntries = allEntries.sort((a, b) => {
  const dateCompare = b.data.publishDate.localeCompare(a.data.publishDate);
  
  // 1. Jika tanggalnya berbeda, gunakan urutan tanggal terbaru
  if (dateCompare !== 0) {
    return dateCompare;
  }
  
  // 2. Jika tanggalnya sama, urutkan berdasarkan versi tertinggi (v2.0.1 di atas v2.0.0)
  return b.data.version.localeCompare(a.data.version, undefined, { numeric: true });
});
---

<BaseLayout
  title="What's New — Envoyou Platform Updates"
  description="Stay up to date with the latest features, improvements, and updates to the Envoyou publishing ecosystem."
>
  <!-- Main Header Navigation -->
  <header class="sticky top-0 z-50 bg-bg/90 backdrop-blur-md border-b border-border transition-colors duration-300">
    <nav class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
      <!-- Back Button & Logo -->
      <div class="flex items-center gap-4">
        <a
          href="/"
          class="flex items-center gap-1.5 text-sm font-semibold text-muted hover:text-text transition-colors duration-200 no-underline"
          aria-label="Back to home"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path d="M19 12H5m7 7l-7-7 7-7"/>
          </svg>
          <span class="hidden sm:inline">Back</span>
        </a>
        <span class="text-border">|</span>
        <a href="/" class="flex items-center gap-1.5 group no-underline">
          <span class="text-base font-bold tracking-tight text-text">Envoyou</span>
        </a>
      </div>

      <!-- Theme Toggle -->
      <button
        id="theme-toggle"
        class="w-9 h-9 rounded-full bg-surface flex items-center justify-center text-muted hover:text-text hover:bg-surface-soft transition-all duration-200 cursor-pointer"
        aria-label="Toggle theme"
      >
        <svg id="icon-sun" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
        <svg id="icon-moon" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </nav>
  </header>

  <main class="min-h-screen bg-surface-soft pb-24 relative overflow-hidden transition-colors duration-300">
    <!-- Ambient Radial Glow -->
    <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_30%_10%,rgba(11,121,194,0.05),transparent_40%),radial-gradient(circle_at_70%_20%,rgba(147,51,234,0.04),transparent_40%)] dark:bg-[radial-gradient(circle_at_30%_10%,rgba(11,121,194,0.09),transparent_40%),radial-gradient(circle_at_70%_20%,rgba(147,51,234,0.06),transparent_40%)]"></div>

    <div class="max-w-4xl mx-auto px-6 pt-16">
      <!-- Header -->
      <div class="mb-12">
        <span class="inline-flex items-center gap-1.5 text-[11px] font-extrabold uppercase tracking-widest text-primary bg-primary/10 px-3 py-1 rounded-full border border-primary/20 mb-4">
          Updates
        </span>
        <h1 class="text-4xl sm:text-5xl font-black tracking-tight text-text mb-4">What's New.</h1>
        <p class="text-muted text-base sm:text-lg max-w-xl leading-relaxed">
          Stay up to date with the latest features, enhancements, and workflow upgrades released in the Envoyou AI Editorial System.
        </p>
      </div>

      <!-- Accordion Timeline List -->
      <div class="space-y-8">
        
        <!-- Table Header (hidden on mobile) -->
        <div class="hidden md:grid grid-cols-4 gap-6 px-8 pb-4 text-xs font-bold text-muted border-b border-border">
          <div class="col-span-1">Version</div>
          <div class="col-span-3">Description</div>
        </div>

        {sortedEntries.map((entry) => {
          const { version, date, color, title, summary, added, changed, fixed, removed } = entry.data;

          const categories = [
            { label: 'New Features', items: added },
            { label: 'Improvements', items: changed },
            { label: 'Fixes', items: fixed },
            { label: 'Removed', items: removed }
          ];

          return (
            <div class="bg-surface border border-border rounded-3xl p-6 md:p-8 space-y-6 hover:border-muted transition-colors duration-200 shadow-sm">
              <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                <!-- Left Column: Version & Date -->
                <div class="col-span-1 space-y-1">
                  <span class={`inline-flex text-[11px] font-black uppercase tracking-widest px-3 py-1 rounded-full border ${
                    color === 'primary' ? 'text-primary bg-primary/10 border-primary/20' : 
                    color === 'emerald' ? 'text-emerald-700 dark:text-emerald-400 bg-emerald-100 dark:bg-emerald-900/40 border-emerald-300/40 dark:border-emerald-700/40' :
                    'text-purple-700 dark:text-purple-400 bg-purple-100 dark:bg-purple-900/40 border-purple-300/40 dark:border-purple-700/40'
                  }`}>
                    v{version}
                  </span>
                  <div class="text-xs font-semibold text-muted font-mono pt-1">{date}</div>
                </div>

                <!-- Right Column: Description & Categories -->
                <div class="col-span-3 space-y-4">
                  <div class="space-y-2">
                    <h3 class="text-xl font-bold tracking-tight text-text">{title}</h3>
                    <p class="text-sm text-muted leading-relaxed">{summary}</p>
                  </div>

                  <!-- Categories Accordion List -->
                  <div class="border-t border-border/60 divide-y divide-border/60 pt-2">
                    {categories.map((cat) => {
                      const hasItems = cat.items && cat.items.length > 0;
                      const itemCount = cat.items ? cat.items.length : 0;
                      
                      if (!hasItems) {
                        return (
                          <div class="flex items-center justify-between py-3 text-xs text-muted/40 cursor-not-allowed select-none">
                            <span>{cat.label} ({itemCount})</span>
                          </div>
                        );
                      }
                      
                      return (
                        <details class="group [&_summary::-webkit-details-marker]:hidden cursor-pointer">
                          <summary class="flex items-center justify-between py-3 text-xs font-bold text-text/80 list-none hover:text-primary transition-colors duration-200">
                            <span>{cat.label} ({itemCount})</span>
                            <span class="transition-transform duration-300 group-open:-rotate-180 text-muted group-hover:text-primary">
                              <ChevronDown class="w-4 h-4" />
                            </span>
                          </summary>
                          <div class="pb-4 pt-1 text-xs text-muted leading-relaxed border-t border-border/30 mt-1">
                            <ul class="space-y-2.5 list-disc list-inside mt-2">
                              {cat.items?.map((item) => (
                                <li class="pl-2 -indent-2">
                                  <strong class="text-text">{item.title}:</strong> <span set:html={item.description} />
                                </li>
                              ))}
                            </ul>
                          </div>
                        </details>
                      );
                    })}
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  // Theme toggle functionality
  const themeToggle = document.getElementById("theme-toggle");
  const iconSun = document.getElementById("icon-sun");
  const iconMoon = document.getElementById("icon-moon");

  function updateIcons() {
    const isDark = document.documentElement.classList.contains("dark");
    iconSun?.classList.toggle("hidden", !isDark);
    iconMoon?.classList.toggle("hidden", isDark);
  }

  updateIcons();

  themeToggle?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    updateIcons();
  });
</script>
