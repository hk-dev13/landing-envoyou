---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="What's New — Envoyou Platform Updates"
  description="Stay up to date with the latest features, improvements, and updates to the Envoyou publishing ecosystem."
>
  <!-- Main Header Navigation -->
  <header class="sticky top-0 z-50 bg-bg/90 backdrop-blur-md border-b border-border transition-colors duration-300">
    <nav class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
      <!-- Back Button & Logo -->
      <div class="flex items-center gap-4">
        <a
          href="/"
          class="flex items-center gap-1.5 text-sm font-semibold text-muted hover:text-text transition-colors duration-200 no-underline"
          aria-label="Back to home"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path d="M19 12H5m7 7l-7-7 7-7"/>
          </svg>
          <span class="hidden sm:inline">Back</span>
        </a>
        <span class="text-border">|</span>
        <a href="/" class="flex items-center gap-1.5 group no-underline">
          <span class="text-base font-bold tracking-tight text-text">Envoyou</span>
        </a>
      </div>

      <!-- Theme Toggle -->
      <button
        id="theme-toggle"
        class="w-9 h-9 rounded-full bg-surface flex items-center justify-center text-muted hover:text-text hover:bg-surface-soft transition-all duration-200 cursor-pointer"
        aria-label="Toggle theme"
      >
        <svg id="icon-sun" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
        <svg id="icon-moon" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </nav>
  </header>

  <main class="min-h-screen bg-surface-soft pb-24 relative overflow-hidden transition-colors duration-300">
    <!-- Ambient Radial Glow -->
    <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_30%_10%,rgba(11,121,194,0.05),transparent_40%),radial-gradient(circle_at_70%_20%,rgba(147,51,234,0.04),transparent_40%)] dark:bg-[radial-gradient(circle_at_30%_10%,rgba(11,121,194,0.09),transparent_40%),radial-gradient(circle_at_70%_20%,rgba(147,51,234,0.06),transparent_40%)]"></div>

    <div class="max-w-2xl mx-auto px-6 pt-16">
      <!-- Header -->
      <div class="mb-16">
        <span class="inline-flex items-center gap-1.5 text-[11px] font-extrabold uppercase tracking-widest text-primary bg-primary/10 px-3 py-1 rounded-full border border-primary/20 mb-4">
          Updates
        </span>
        <h1 class="text-4xl sm:text-5xl font-black tracking-tight text-text mb-4">What's New.</h1>
        <p class="text-muted text-base sm:text-lg max-w-xl leading-relaxed">
          Stay up to date with the latest features, enhancements, and workflow upgrades released in the Envoyou AI Editorial System.
        </p>
      </div>

      <!-- Timeline / Changelog List -->
      <div class="relative pl-6 sm:pl-8 border-l border-border space-y-16">

        <!-- VERSION 1.1.0 -->
        <div class="relative">
          <div class="absolute -left-[31px] sm:-left-[39px] top-1.5 w-4.5 h-4.5 rounded-full border-4 border-bg bg-emerald-500 shadow-sm"></div>

          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-4">
            <h2 class="text-2xl font-extrabold text-text">v1.1.0</h2>
            <time class="text-xs font-semibold text-muted font-mono">29 June 2026</time>
          </div>

          <div class="space-y-6">
            <div>
              <span class="inline-flex text-[10px] font-black uppercase tracking-wider text-emerald-700 dark:text-emerald-400 bg-emerald-100 dark:bg-emerald-900/40 px-2 py-0.5 rounded border border-emerald-300/40 dark:border-emerald-700/40 mb-3">
                Added
              </span>
              <ul class="space-y-2.5 text-sm text-text/80 leading-relaxed list-disc list-inside">
                <li>
                  <strong class="text-text">Compact Sources Panel (Mobile):</strong> Reference sources now appear more compact without covering the typing area.
                </li>
                <li>
                  <strong class="text-text">Floating Back Button:</strong> Mobile navigation is simpler and provides a wider workspace.
                </li>
                <li>
                  <strong class="text-text">Smarter Mobile Sidebar:</strong> The sidebar now automatically closes when first opened on small screens.
                </li>
              </ul>
            </div>

            <div>
              <span class="inline-flex text-[10px] font-black uppercase tracking-wider text-amber-700 dark:text-amber-400 bg-amber-100 dark:bg-amber-900/40 px-2 py-0.5 rounded border border-amber-300/40 dark:border-amber-700/40 mb-3">
                Changed
              </span>
              <ul class="space-y-2.5 text-sm text-text/80 leading-relaxed list-disc list-inside">
                <li>
                  <strong class="text-text">Touch Interactions:</strong> Touch interactions are more consistent on mobile phones and tablets.
                </li>
                <li>
                  <strong class="text-text">Editor Stability:</strong> The editor is more stable when switching between content.
                </li>
              </ul>
            </div>

            <div>
              <span class="inline-flex text-[10px] font-black uppercase tracking-wider text-rose-700 dark:text-rose-400 bg-rose-100 dark:bg-rose-900/40 px-2 py-0.5 rounded border border-rose-300/40 dark:border-rose-700/40 mb-3">
                Fixed
              </span>
              <ul class="space-y-2.5 text-sm text-text/80 leading-relaxed list-disc list-inside">
                <li>
                  <strong class="text-text">Editor Sync:</strong> Fixed cases where the editor does not immediately sync after AI generates content.
                </li>
                <li>
                  <strong class="text-text">Editor Warning Cleanup:</strong> Reduced warnings and inconsistent behavior on the editor page.
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- VERSION 1.0.0 -->
        <div class="relative">
          <div class="absolute -left-[31px] sm:-left-[39px] top-1.5 w-4.5 h-4.5 rounded-full border-4 border-bg bg-purple-500 shadow-sm"></div>

          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-4">
            <h2 class="text-2xl font-extrabold text-text">v1.0.0</h2>
            <time class="text-xs font-semibold text-muted font-mono">29 June 2026</time>
          </div>

          <div class="space-y-6">
            <div>
              <span class="inline-flex text-[10px] font-black uppercase tracking-wider text-emerald-700 dark:text-emerald-400 bg-emerald-100 dark:bg-emerald-900/40 px-2 py-0.5 rounded border border-emerald-300/40 dark:border-emerald-700/40 mb-3">
                Added
              </span>
              <ul class="space-y-2.5 text-sm text-text/80 leading-relaxed list-disc list-inside">
                <li>
                  <strong class="text-text">New Rich Text Editor:</strong> Writing is now more comfortable with a new block-based visual editor and modern formatting.
                </li>
                <li>
                  <strong class="text-text">AI Slash Commands (`/`):</strong> Type `/` to run quick actions such as generating paragraphs, SEO optimization, and other writing assistance.
                </li>
                <li>
                  <strong class="text-text">AI Review Before Apply:</strong> All AI-generated changes now appear as a preview that you can **Accept** or **Reject** before applying.
                </li>
                <li>
                  <strong class="text-text">Research Notes:</strong> Save research results and reuse them when drafting.
                </li>
                <li>
                  <strong class="text-text">Generate Draft from Notes:</strong> Automatically turn a collection of research notes into a first draft.
                </li>
                <li>
                  <strong class="text-text">Research Copilot:</strong> An interactive research assistant with streaming answers, real-time search, and browsable sources.
                </li>
              </ul>
            </div>

            <div>
              <span class="inline-flex text-[10px] font-black uppercase tracking-wider text-amber-700 dark:text-amber-400 bg-amber-100 dark:bg-amber-900/40 px-2 py-0.5 rounded border border-amber-300/40 dark:border-amber-700/40 mb-3">
                Changed
              </span>
              <ul class="space-y-2.5 text-sm text-text/80 leading-relaxed list-disc list-inside">
                <li>
                  <strong class="text-text">Fast Mode:</strong> **Fast** mode is now quicker for short questions.
                </li>
                <li>
                  <strong class="text-text">Deep Research Mode:</strong> **Deep Research** mode is more stable for long research.
                </li>
                <li>
                  <strong class="text-text">Editor Responsiveness:</strong> The editor feels more responsive with large documents.
                </li>
                <li>
                  <strong class="text-text">Dark Mode Refresh:</strong> The dark mode visual style has been updated to be more comfortable for extended use.
                </li>
              </ul>
            </div>

            <div>
              <span class="inline-flex text-[10px] font-black uppercase tracking-wider text-rose-700 dark:text-rose-400 bg-rose-100 dark:bg-rose-900/40 px-2 py-0.5 rounded border border-rose-300/40 dark:border-rose-700/40 mb-3">
                Fixed
              </span>
              <ul class="space-y-2.5 text-sm text-text/80 leading-relaxed list-disc list-inside">
                <li>
                  <strong class="text-text">Authentication & Redirects:</strong> Fixed several login and redirect issues.
                </li>
                <li>
                  <strong class="text-text">Draft Language Consistency:</strong> Fixed draft output sometimes being mixed-language.
                </li>
                <li>
                  <strong class="text-text">Source Deduplication:</strong> Fixed source duplication in blueprint results.
                </li>
                <li>
                  <strong class="text-text">Performance & Stability:</strong> Fixed several stability and performance issues.
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- VERSION 0.35.0 -->
        <div class="relative">
          <div class="absolute -left-[31px] sm:-left-[39px] top-1.5 w-4.5 h-4.5 rounded-full border-4 border-bg bg-primary shadow-sm"></div>

          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-4">
            <h2 class="text-2xl font-extrabold text-text">v0.35.0</h2>
            <time class="text-xs font-semibold text-muted font-mono">21 June 2026</time>
          </div>

          <div class="space-y-6">
            <div>
              <span class="inline-flex text-[10px] font-black uppercase tracking-wider text-emerald-700 dark:text-emerald-400 bg-emerald-100 dark:bg-emerald-900/40 px-2 py-0.5 rounded border border-emerald-300/40 dark:border-emerald-700/40 mb-3">
                Added
              </span>
              <ul class="space-y-2.5 text-sm text-text/80 leading-relaxed list-disc list-inside">
                <li>
                  <strong class="text-text">Workspace Routing:</strong> Added the `/workspace` route as the central hub for content management and editorial projects.
                </li>
                <li>
                  <strong class="text-text">Editorial Workspace Component:</strong> Created a new `EditorialWorkspace` component as the primary interface for managing workspaces.
                </li>
                <li>
                  <strong class="text-text">Demo Page:</strong> Introduced a `/demo` page demonstrating full application features.
                </li>
              </ul>
            </div>

            <div>
              <span class="inline-flex text-[10px] font-black uppercase tracking-wider text-amber-700 dark:text-amber-400 bg-amber-100 dark:bg-amber-900/40 px-2 py-0.5 rounded border border-amber-300/40 dark:border-amber-700/40 mb-3">
                Changed
              </span>
              <ul class="space-y-2.5 text-sm text-text/80 leading-relaxed list-disc list-inside">
                <li>
                  <strong class="text-text">Pricing Relocation:</strong> Relocated EAI's `/pricing` page to the main landing page (`envoyou.com/pricing`).
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- VERSION 0.34.0 -->
        <div class="relative">
          <div class="absolute -left-[31px] sm:-left-[39px] top-1.5 w-4.5 h-4.5 rounded-full border-4 border-bg bg-purple-500 shadow-sm"></div>

          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-4">
            <h2 class="text-2xl font-extrabold text-text">v0.34.0</h2>
            <time class="text-xs font-semibold text-muted font-mono">21 June 2026</time>
          </div>

          <div class="space-y-6">
            <div>
              <span class="inline-flex text-[10px] font-black uppercase tracking-wider text-amber-700 dark:text-amber-400 bg-amber-100 dark:bg-amber-900/40 px-2 py-0.5 rounded border border-amber-300/40 dark:border-amber-700/40 mb-3">
                Changed
              </span>
              <ul class="space-y-2.5 text-sm text-text/80 leading-relaxed list-disc list-inside">
                <li>
                  <strong class="text-text">NIB & PSE Compliance:</strong> Implemented Indonesian NIB (Business Identification Number) and Kominfo PSE (Electronic System Operator) registration disclosures in Terms of Service and Privacy Policy.
                </li>
                <li>
                  <strong class="text-text">Data Processor Registry:</strong> Updated data processors list in Privacy Policy to accurately reflect our distributed infrastructure: Clerk (Auth), Vercel (Frontend), DO (EAI VPS), Biznet Gio (Blog VPS), Supabase & Neon (Databases), Cloudflare (DNS/WAF), Gemini API (sole AI provider), and Midtrans (sole payment gateway).
                </li>
                <li>
                  <strong class="text-text">Cross-Border Data Transfers:</strong> Added a cross-border data transfer disclosure in compliance with Indonesian UU PDP No. 27/2022 and GDPR Article 6.
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- VERSION 0.33.0 -->
        <div class="relative">
          <div class="absolute -left-[31px] sm:-left-[39px] top-1.5 w-4.5 h-4.5 rounded-full border-4 border-bg bg-emerald-500 shadow-sm"></div>

          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-4">
            <h2 class="text-2xl font-extrabold text-text">v0.33.0</h2>
            <time class="text-xs font-semibold text-muted font-mono">18 June 2026</time>
          </div>

          <div class="space-y-6">
            <div>
              <span class="inline-flex text-[10px] font-black uppercase tracking-wider text-emerald-700 dark:text-emerald-400 bg-emerald-100 dark:bg-emerald-900/40 px-2 py-0.5 rounded border border-emerald-300/40 dark:border-emerald-700/40 mb-3">
                Added
              </span>
              <ul class="space-y-2.5 text-sm text-text/80 leading-relaxed list-disc list-inside">
                <li>
                  <strong class="text-text">Account Settings:</strong> Added a new Account Settings page under `/settings/account`.
                </li>
              </ul>
            </div>

            <div>
              <span class="inline-flex text-[10px] font-black uppercase tracking-wider text-amber-700 dark:text-amber-400 bg-amber-100 dark:bg-amber-900/40 px-2 py-0.5 rounded border border-amber-300/40 dark:border-amber-700/40 mb-3">
                Changed
              </span>
              <ul class="space-y-2.5 text-sm text-text/80 leading-relaxed list-disc list-inside">
                <li>
                  <strong class="text-text">Borderless UI Theme:</strong> Implemented a borderless design system where the header, tab bars, and status bars blend seamlessly with the main background.
                </li>
                <li>
                  <strong class="text-text">Refined Tab Styling:</strong> Polished hover effects on document tabs (Preview, Markdown, Changes) and active tab indicators.
                </li>
                <li>
                  <strong class="text-text">Minimalist Status Bar:</strong> Cleaned up the status bar text elements by removing badge backgrounds.
                </li>
                <li>
                  <strong class="text-text">Adaptive Sidebar Backgrounds:</strong> Workspace sidebar background colors now dynamically adjust based on open/closed state.
                </li>
                <li>
                  <strong class="text-text">Single AI Provider Focus:</strong> Removed provider switching from the user interface; EAI now exclusively runs on Google Gemini for all editorial pipeline requests.
                </li>
              </ul>
            </div>

            <div>
              <span class="inline-flex text-[10px] font-black uppercase tracking-wider text-rose-700 dark:text-rose-400 bg-rose-100 dark:bg-rose-900/40 px-2 py-0.5 rounded border border-rose-300/40 dark:border-rose-700/40 mb-3">
                Removed
              </span>
              <ul class="space-y-2.5 text-sm text-text/80 leading-relaxed list-disc list-inside">
                <li>
                  <strong class="text-text">Activity Bar Component:</strong> Removed the `ActivityBar` to simplify editor space.
                </li>
              </ul>
            </div>

          </div>
        </div>

        <!-- VERSION 0.32.0 -->
        <div class="relative">
          <div class="absolute -left-[31px] sm:-left-[39px] top-1.5 w-4.5 h-4.5 rounded-full border-4 border-bg bg-primary shadow-sm"></div>

          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-4">
            <h2 class="text-2xl font-extrabold text-text">v0.32.0</h2>
            <time class="text-xs font-semibold text-muted font-mono">15 June 2026</time>
          </div>

          <div class="space-y-6">
            <div>
              <span class="inline-flex text-[10px] font-black uppercase tracking-wider text-amber-700 dark:text-amber-400 bg-amber-100 dark:bg-amber-900/40 px-2 py-0.5 rounded border border-amber-300/40 dark:border-amber-700/40 mb-3">
                Changed
              </span>
              <ul class="space-y-2.5 text-sm text-text/80 leading-relaxed list-disc list-inside">
                <li>
                  <strong class="text-text">Clear Availability Pages:</strong> Added branded status experiences for scheduled maintenance and temporarily unavailable signup or pricing features, with direct access to support.
                </li>
              </ul>
            </div>

            <div>
              <span class="inline-flex text-[10px] font-black uppercase tracking-wider text-rose-700 dark:text-rose-400 bg-rose-100 dark:bg-rose-900/40 px-2 py-0.5 rounded border border-rose-300/40 dark:border-rose-700/40 mb-3">
                Fixed
              </span>
              <ul class="space-y-2.5 text-sm text-text/80 leading-relaxed list-disc list-inside">
                <li>
                  <strong class="text-text">Consistent Feature Availability:</strong> Navigation, authentication pages, editorial processing, checkout, and CMS export now follow the latest service availability settings.
                </li>
                <li>
                  <strong class="text-text">More Helpful Recovery Screens:</strong> Replaced generic server errors with clearer guidance and surfaced operational messages when AI processing or related services are temporarily unavailable.
                </li>
                <li>
                  <strong class="text-text">Reliable Maintenance Access:</strong> Status and recovery pages remain available even when service configuration is slow or temporarily unreachable.
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- VERSION 0.31.2 -->
        <div class="relative">
          <div class="absolute -left-[31px] sm:-left-[39px] top-1.5 w-4.5 h-4.5 rounded-full border-4 border-bg bg-purple-500 shadow-sm"></div>

          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-4">
            <h2 class="text-2xl font-extrabold text-text">v0.31.2</h2>
            <time class="text-xs font-semibold text-muted font-mono">15 June 2026</time>
          </div>

          <div class="space-y-6">
            <div>
              <span class="inline-flex text-[10px] font-black uppercase tracking-wider text-rose-700 dark:text-rose-400 bg-rose-100 dark:bg-rose-900/40 px-2 py-0.5 rounded border border-rose-300/40 dark:border-rose-700/40 mb-3">
                Fixed
              </span>
              <ul class="space-y-2.5 text-sm text-text/80 leading-relaxed list-disc list-inside">
                <li>
                  <strong class="text-text">Improved Error Monitoring:</strong> Strengthened error reporting so production issues can be diagnosed more quickly and accurately.
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- VERSION 0.31.1 -->
        <div class="relative">
          <div class="absolute -left-[31px] sm:-left-[39px] top-1.5 w-4.5 h-4.5 rounded-full border-4 border-bg bg-emerald-500 shadow-sm"></div>

          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-4">
            <h2 class="text-2xl font-extrabold text-text">v0.31.1</h2>
            <time class="text-xs font-semibold text-muted font-mono">15 June 2026</time>
          </div>

          <div class="space-y-6">
            <div>
              <span class="inline-flex text-[10px] font-black uppercase tracking-wider text-emerald-700 dark:text-emerald-400 bg-emerald-100 dark:bg-emerald-900/40 px-2 py-0.5 rounded border border-emerald-300/40 dark:border-emerald-700/40 mb-3">
                Added
              </span>
              <ul class="space-y-2.5 text-sm text-text/80 leading-relaxed list-disc list-inside">
                <li>
                  <strong class="text-text">Easier Help and Update Access:</strong> Added direct Support and Changelog links to the login page navigation.
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- VERSION 0.31.0 -->
        <div class="relative">
          <div class="absolute -left-[31px] sm:-left-[39px] top-1.5 w-4.5 h-4.5 rounded-full border-4 border-bg bg-purple-500 shadow-sm"></div>

          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-4">
            <h2 class="text-2xl font-extrabold text-text">v0.31.0</h2>
            <time class="text-xs font-semibold text-muted font-mono">15 June 2026</time>
          </div>

          <div class="space-y-6">
            <div>
              <span class="inline-flex text-[10px] font-black uppercase tracking-wider text-emerald-700 dark:text-emerald-400 bg-emerald-100 dark:bg-emerald-900/40 px-2 py-0.5 rounded border border-emerald-300/40 dark:border-emerald-700/40 mb-3">
                Added
              </span>
              <ul class="space-y-2.5 text-sm text-text/80 leading-relaxed list-disc list-inside">
                <li>
                  <strong class="text-text">Organization-First Onboarding:</strong> New users now create or select their Clerk organization before configuring publication identity, editorial standards, and optional CMS access.
                </li>
                <li>
                  <strong class="text-text">Safer Workspace Trials:</strong> Eligible workspace creators receive 10 trial credits once, while invited members no longer create duplicate trial allocations.
                </li>
                <li>
                  <strong class="text-text">Expanded Workspace Settings:</strong> Added dedicated settings for user preferences, organizations, plans and credits, publication configuration, feature controls, and telemetry.
                </li>
                <li>
                  <strong class="text-text">Focused Editorial Analytics:</strong> The dashboard now provides dedicated views for overview, performance, trends, and productivity.
                </li>
              </ul>
            </div>

            <div>
              <span class="inline-flex text-[10px] font-black uppercase tracking-wider text-amber-700 dark:text-amber-400 bg-amber-100 dark:bg-amber-900/40 px-2 py-0.5 rounded border border-amber-300/40 dark:border-amber-700/40 mb-3">
                Changed
              </span>
              <ul class="space-y-2.5 text-sm text-text/80 leading-relaxed list-disc list-inside">
                <li>
                  <strong class="text-text">Refined Editorial Workspace:</strong> Updated navigation, panels, controls, responsive behavior, accessibility, and wording across the editor and settings experience.
                </li>
                <li>
                  <strong class="text-text">Clearer Workspace Identity:</strong> Organization names and slugs now stay aligned with Clerk, and Use Defaults configures the active workspace without creating a second local organization.
                </li>
              </ul>
            </div>

            <div>
              <span class="inline-flex text-[10px] font-black uppercase tracking-wider text-rose-700 dark:text-rose-400 bg-rose-100 dark:bg-rose-900/40 px-2 py-0.5 rounded border border-rose-300/40 dark:border-rose-700/40 mb-3">
                Fixed
              </span>
              <ul class="space-y-2.5 text-sm text-text/80 leading-relaxed list-disc list-inside">
                <li>
                  <strong class="text-text">Isolated Onboarding Progress:</strong> Draft configuration and CMS credentials no longer carry over when switching organizations.
                </li>
                <li>
                  <strong class="text-text">More Reliable Quality Signals:</strong> Empty risk responses such as "All clear" and "No risks found" are no longer shown as critical editorial flags.
                </li>
                <li>
                  <strong class="text-text">Stable Editor Menus:</strong> Select and refined-draft download menus now stay anchored correctly while panels resize or scroll.
                </li>
              </ul>
            </div>
          </div>
