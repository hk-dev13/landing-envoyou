---
// Footer component
---

<footer class="border-t border-border bg-surface">
  <div class="max-w-[90rem] mx-auto px-6 py-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-1.5 mb-4">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center shadow-md group-hover:brightness-110 transition-all duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="25" height="25">
              <g fill="#0b79c2">
                <path d="M222 7.5c-44.3 5.9-84.2 22.3-120.8 49.7-15.1 11.3-36.8 33.4-50.3 51.4-.9 1.2-4.7 1.8 76.6-13.1 87-15.9 105.8-19.4 169-31 31.9-5.9 66-12.1 75.8-13.9 9.8-1.7 17.8-3.6 17.8-4.1-.1-2.6-32.5-19.3-50.2-25.9-12.3-4.5-33.4-10-47.4-12.1-14.9-2.4-55.9-2.9-70.5-1M441.6 96.8c-2.8 6.8-12.7 16.3-19.6 18.9-3 1.1-20.6 4.8-39 8.2-18.4 3.3-45.9 8.3-61 11.1s-48.2 8.9-73.5 13.5C46.3 185.6 11.6 192 11 192.7c-1.1 1.2-4.9 20.4-6.5 32.8-.8 6-1.5 15.9-1.5 21.8v10.9l2.7-.6c1.6-.3 35-6 74.3-12.6 39.3-6.7 80.3-13.6 91-15.5 93.6-16.4 163-27.7 168.1-27.2 8.3.7 16.9 5 22.9 11.3 7.7 8.1 9.5 12.8 9.5 24.9 0 8.8-.3 10.7-2.7 15.7-3.4 7.3-10.4 14.3-17.4 17.5-5.5 2.5-7.7 2.9-97.9 18.3-29.1 4.9-207.5 35.4-225.3 38.4-7.3 1.3-13.5 2.6-13.9 2.9-.8.9 4.8 16.8 10.4 29.1 4.1 9.2 14.5 28.5 17.8 32.9 1.4 2-5.7 3.1 141-22.4 67.2-11.7 76.1-13.1 82.5-12.7 12.8.7 24.4 8.7 30.2 20.7 2.9 5.9 3.2 7.5 3.2 15.1-.1 19-11.3 32.6-30.1 36.5-3.8.8-21.4 3.9-39.3 7s-44.2 7.6-58.5 10.1-35 6-45.9 7.9-20.1 3.6-20.3 3.9c-.9.9 21.7 14.9 34.7 21.5 24.1 12.2 49.8 20.6 76.3 24.8 14.1 2.2 58.4 2.5 71.7.5 21.2-3.3 39.8-8.2 57-14.9 77.7-30.5 135.7-97.7 153.8-178.3 5-22.2 5.7-29.4 5.7-56.5 0-27.3-1.2-37.5-6.5-59.3-8.4-34.4-25.3-69-47.2-96.5-3.8-4.8-7-8.7-7.1-8.7s-1.1 2.1-2.1 4.8"/>
              </g>
            </svg>
          </div>
          <span class="text-lg font-bold text-text">Envoyou</span>
        </a>
        <p class="text-muted text-sm leading-6 max-w-xs">
          Publishing, editorial intelligence, and content operations — connected in one ecosystem.
        </p>
        <div class="flex items-center gap-3 mt-6">
          <span class="text-sm text-muted transition-colors font-medium">Create. Refine. Publish.</span>
        </div>
        <div class="flex items-center gap-4 mt-6">
          <a
            href="https://github.com/Envoyou"
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted hover:text-text transition-colors"
            aria-label="GitHub"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
              <path d="M9 18c-4.51 2-5-2-7-2"></path>
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/husni-kusuma"
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted hover:text-text transition-colors"
            aria-label="LinkedIn"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </a>
          <a
            href="https://x.com/EnvoyouAPI"
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted hover:text-text transition-colors"
            aria-label="X"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4l11.733 16h4.267l-11.733 -16z"></path>
              <path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Products -->
      <div>
        <h3 class="text-sm font-semibold text-text mb-4">Products</h3>
        <ul class="space-y-2.5">
          <li>
            <a href="https://blog.envoyou.com" target="_blank" class="text-sm text-muted hover:text-text transition-colors">
              E-Blog
            </a>
          </li>
          <li>
            <a href="https://eai.envoyou.com" target="_blank" class="text-sm text-muted hover:text-text transition-colors">
              EAI Editorial Intelligence
            </a>
          </li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-semibold text-text mb-4">Company</h3>
        <ul class="space-y-2.5">
          <li>
            <a href="/about" class="text-sm text-muted hover:text-text transition-colors">
              About
            </a>
          </li>
          <li>
            <a href="/#products" class="text-sm text-muted hover:text-text transition-colors">
              Products
            </a>
          </li>
          <li>
            <a href="/#analytics" class="text-sm text-muted hover:text-text transition-colors">
              Analytics
            </a>
          </li>
          <li>
            <a href="/changelog" class="text-sm text-muted hover:text-text transition-colors">
              Changelog
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-border flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex flex-col items-center md:items-start gap-1">
        <p class="text-xs text-muted">
          &copy; {new Date().getFullYear()} Envoyou. All rights reserved.
        </p>
        <p class="text-[10px] text-muted/70">
          Operated from Banyuwangi, Jawa Timur, Indonesia.
        </p>
      </div>

      <div class="flex items-center gap-5 text-xs text-muted">
        <a href="/terms" class="hover:text-text transition-colors">Terms</a>
        <a href="/privacy" class="hover:text-text transition-colors">Privacy</a>
        <a href="/refund" class="hover:text-text transition-colors">Refund Policy</a>
      </div>

      <div class="flex items-center gap-1.5">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-success animate-pulse"></span>
        <span class="text-xs text-muted">Continuously publishing</span>
      </div>
    </div>
  </div>
</footer>
