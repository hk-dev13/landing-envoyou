              </g>
            </svg>
          </div>
          <span class="text-lg font-bold text-text">Envoyou</span>
        </a>
        <p class="text-muted text-sm leading-6 max-w-xs">
          Build with the ambition of the world's best. Measure progress against who you were six months ago.
        </p>
        <div class="flex items-center gap-3 mt-6">
          <span class="text-sm text-muted transition-colors font-medium">Create — Refine — Review — Publish</span>
        </div>
        <div class="flex items-center gap-4 mt-6">
          <a
            href="https://github.com/Envoyou"
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted hover:text-text transition-colors"
            aria-label="GitHub"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
              <path d="M9 18c-4.51 2-5-2-7-2"></path>
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/husni-kusuma"
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted hover:text-text transition-colors"
            aria-label="LinkedIn"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </a>
          <a
            href="https://x.com/EnvoyouAPI"
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted hover:text-text transition-colors"
            aria-label="X"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4l11.733 16h4.267l-11.733 -16z"></path>
              <path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Products -->
      <div class="md:justify-self-end">
        <h3 class="text-sm font-semibold text-text mb-4">Products</h3>
        <ul class="space-y-2.5">
          <li>
            <a href="https://blog.envoyou.com" target="_blank" class="text-sm text-muted hover:text-text transition-colors">
              E-Blog
            </a>
          </li>
          <li>
            <a
              href="https://eai.envoyou.com"
              target="_blank"
              rel="noopener noreferrer"
              data-analytics-event="eai_outbound_clicked"
              data-analytics-location="footer"
              class="text-sm text-muted hover:text-text transition-colors"
            >
              EAI Editorial Intelligence
            </a>
          </li>
          <li>
            <a href="/integrations/custom-cms/" class="text-sm text-muted hover:text-text transition-colors">
              CMS Integrations
            </a>
          </li>
          <li>
            <a href="/solutions/small-publishers/" class="text-sm text-muted hover:text-text transition-colors">
              Small Publishers
            </a>
          </li>
        </ul>
      </div>

      <!-- Company -->
      <div class="md:justify-self-end">
        <h3 class="text-sm font-semibold text-text mb-4">Company</h3>
        <ul class="space-y-2.5">
          <li>
            <a href="/about" class="text-sm text-muted hover:text-text transition-colors">
              About
            </a>
          </li>
          <li>
            <a href="/#products" class="text-sm text-muted hover:text-text transition-colors">
              Products
            </a>
          </li>
          <li>
            <a href="/#analytics" class="text-sm text-muted hover:text-text transition-colors">
              Analytics
            </a>
          </li>
          <li>
            <a href="/changelog" class="text-sm text-muted hover:text-text transition-colors">
              Changelog
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-border flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex flex-col items-center md:items-start gap-1">
        <p class="text-xs text-muted">
          &copy; {new Date().getFullYear()} Envoyou. All rights reserved.
        </p>
        <p class="text-[10px] text-muted/70">
          Banyuwangi, Jawa Timur, Indonesia.
        </p>
      </div>

      <div class="flex items-center gap-8 text-xs text-muted">
        <a href="/terms" class="hover:text-text transition-colors">Terms</a>
        <a href="/privacy" class="hover:text-text transition-colors">Privacy</a>
        <a href="/refund" class="hover:text-text transition-colors">Refund Policy</a>
      </div>

      <div class="flex items-center gap-1.5">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-success animate-pulse"></span>
        <a href="https://status.envoyou.com" target="_blank" rel="noopener noreferrer" class="text-xs text-muted hover:text-text transition-colors">System Status</a>
      </div>
    </div>
  </div>
</footer>
