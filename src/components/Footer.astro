---
// Footer component
---

<footer class="border-t border-border bg-surface">
  <div class="max-w-[100rem] mx-auto px-6 py-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-1.5 mb-4">
          <div class="w-8 h-8 flex items-center justify-center group-hover:brightness-110 transition-all duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 600" width="25" height="25">
              <g fill="currentColor">
