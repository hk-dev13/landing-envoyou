---
const outcomes = [
  "Refine under your editorial profile",
  "Surface unsupported or altered claims",
  "Prepare the draft and SEO package together",
];
---

<section
  id="hero"
  class="relative min-h-[78vh] flex items-center pt-20 overflow-hidden"
>
  <div class="hero-bg"></div>

  <div class="section relative z-10 w-full">
    <div class="max-w-5xl">
      <div class="section-label">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-primary"></span>
        Editorial Intelligence for Modern Publishing
      </div>

      <h1
        class="relative text-[clamp(2.5rem,7vw,5.5rem)] font-black tracking-[-0.055em] leading-[0.96] text-text max-w-5xl"
        aria-label="Turn raw drafts into verified, publication-ready articles."
      >
        <span class="invisible" aria-hidden="true">
          Turn raw drafts into verified,<br class="hidden sm:block" />
          <span class="sm:whitespace-nowrap">publication-ready articles.</span>
        </span>
        <span class="absolute inset-0" aria-hidden="true">
          <span data-scramble-text="Turn raw drafts into verified,">Turn raw drafts into verified,</span><br class="hidden sm:block" />
          <span class="text-primary sm:whitespace-nowrap" data-scramble-text="publication-ready articles.">publication-ready articles.</span>
        </span>
      </h1>

      <p class="section-subtitle mt-7 max-w-2xl text-lg">
        EAI brings editorial refinement, claim review, SEO preparation, and CMS draft export into one controlled workflow for independent publishers and lean content teams.
      </p>

      <div class="flex flex-wrap items-center gap-3 mt-10">
        <a
          href="https://eai.envoyou.com/login"
          id="hero-cta-eai-login"
          data-analytics-event="eai_login_clicked"
          data-analytics-location="homepage_hero"
          class="btn-primary"
        >
          Log in to EAI
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M7 17L17 7M17 7H7M17 7v10"/>
          </svg>
        </a>
        <a href="#product-preview" id="hero-cta-features" class="btn-secondary">
          See how it works
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
      <p class="text-xs text-muted mt-3 pl-1">
        New eligible workspaces receive 10 trial credits. No payment card is required to start.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mt-14 pt-8 border-t border-border">
        {outcomes.map((outcome) => (
          <div class="flex items-start gap-3 rounded-2xl border border-border bg-surface/70 px-4 py-4 backdrop-blur-sm">
            <svg class="w-4 h-4 text-primary shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M20 6L9 17l-5-5"/>
            </svg>
            <p class="text-sm font-semibold leading-5 text-text">{outcome}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const FRAME_INTERVAL_MS = 32;
  const LINE_DURATION_MS = 1200; // Diturunkan ke 1.2s agar tidak terlalu lama menunggu
  const BETWEEN_LINES_DELAY_MS = 150; // Dinaikkan sedikit agar jeda antar kalimat terasa natural
  const LINE_REVEAL_DURATION_MS = 420;

  // Kumpulan karakter acak futuristik kustom
  const SCRAMBLE_POOL = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&*+/=";

  const hero = document.querySelector<HTMLElement>('#hero');
  const lines = hero
    ? Array.from(hero.querySelectorAll<HTMLElement>('[data-scramble-text]'))
    : [];
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const wait = (duration: number) =>
    new Promise<void>((resolve) => window.setTimeout(resolve, duration));

  const scrambleLine = (element: HTMLElement) =>
    new Promise<void>((resolve) => {
      const target = element.dataset.scrambleText ?? element.textContent ?? '';
      const targetCharacters = Array.from(target);
      
      // Ambil indeks posisi karakter yang valid di awal (bukan di dalam loop frame)
      const letterPositions = targetCharacters
        .map((char, index) => (/[A-Za-z0-9]/.test(char) ? index : -1))
        .filter((index) => index >= 0);

      let startedAt: number | undefined;
      let lastRenderedAt = -Infinity;

      const renderFrame = (timestamp: number) => {
        startedAt ??= timestamp;

        const elapsed = timestamp - startedAt;
        const progress = Math.min(elapsed / LINE_DURATION_MS, 1);
        
        // Kalkulasi progres penguncian huruf dari kiri ke kanan
        const lockedCount = Math.floor(progress * letterPositions.length);
        const lockedThrough = letterPositions[lockedCount - 1] ?? -1;

        if (timestamp - lastRenderedAt >= FRAME_INTERVAL_MS || progress === 1) {
          element.innerHTML = targetCharacters
            .map((character, index) => {
              // Jika berupa spasi/simbol atau sudah waktunya mengunci, tampilkan teks asli
              if (!/[A-Za-z0-9]/.test(character) || index <= lockedThrough) {
                return character;
              }

              // Suntikkan karakter acak eksternal dengan gaya redup (Tailwind)
              const randomChar = SCRAMBLE_POOL[Math.floor(Math.random() * SCRAMBLE_POOL.length)];
              return `<span class="opacity-40 font-mono text-sky-400">${randomChar}</span>`;
            })
            .join('');
          
          lastRenderedAt = timestamp;
        }

        if (progress < 1) {
          window.requestAnimationFrame(renderFrame);
          return;
        }

        // Kembalikan ke teks murni bawaan saat animasi selesai penuh
        element.textContent = target;
        resolve();
      };

      window.requestAnimationFrame(renderFrame);
    });

  const revealLine = async (element: HTMLElement) => {
    element.style.opacity = '1';
    const animation = element.animate(
      [
        { opacity: 0, transform: 'translateY(4px)' },
        { opacity: 1, transform: 'translateY(0px)' },
      ],
      {
        duration: LINE_REVEAL_DURATION_MS,
        easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
        fill: 'both',
      },
    );

    await animation.finished;
    animation.cancel();
    element.style.opacity = '';
  };

  const runScrambleSequence = async () => {
    if (lines.length === 0) return;

    // Eksekusi baris pertama terlebih dahulu secara mandiri
    await scrambleLine(lines[0]);

    // Eksekusi sisa baris berikutnya secara berurutan satu per satu
    for (let i = 1; i < lines.length; i++) {
      const line = lines[i];
      await wait(BETWEEN_LINES_DELAY_MS);
      
      // Jalankan animasi kemunculan pudar berbarengan dengan proses pengacakan teksnya
      await Promise.all([scrambleLine(line), revealLine(line)]);
    }
  };

  if (!prefersReducedMotion && lines.length > 0) {
    // Sembunyikan semua baris setelah baris pertama di awal render untuk mencegah teks berkedip
    lines.slice(1).forEach((line) => {
      line.style.opacity = '0';
    });

    void runScrambleSequence();
  }
</script>

