---
import stats from '../../data/stats.json';

// EAI operational metrics from stats.json
const cmsExportSuccess = stats.eai?.cmsExportSuccess || "—";
const seoCompletionRate = stats.eai?.seoCompletionRate || "—";
const avgProcessTimeMins = stats.eai?.avgProcessTimeMins;
const eaiUpdatedAt = stats.eaiUpdatedAt;
---

<section
  id="hero"
  class="relative min-h-[80vh] flex items-center pt-16 overflow-hidden"
>
  <!-- Subtle background gradient -->
  <div class="hero-bg"></div>

  <div class="section relative z-10 w-full">
    <div class="max-w-4xl">
      <!-- Label -->
      <div class="section-label">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-primary"></span>
        The Envoyou Ecosystem
      </div>

      <!-- Headline -->
      <h1 class="section-title">
        Publishing Intelligence,<br />
        <span class="text-primary">Redefined.</span>
      </h1>

      <p class="section-subtitle mt-5 max-w-xl">
        Envoyou provides an AI editorial workspace designed to polish raw drafts, verify factual integrity, optimize SEO, and export directly to your custom CMS.
      </p>

      <!-- CTA Buttons -->
      <div>
        <div class="flex flex-wrap items-center gap-3 mt-10">
          <a
            href="#tally-open=ODy5xM&tally-emoji-text=👋&tally-emoji-animation=wave&ref=hero"
            id="hero-cta-eai-login"
            data-analytics-event="beta_access_clicked"
            data-analytics-location="homepage_hero"
            class="btn-primary"
          >
            Request Beta Access
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M7 17L17 7M17 7H7M17 7v10"/>
            </svg>
          </a>
          <a
            href="#products"
            id="hero-cta-features"
            class="btn-secondary"
          >
            Explore Features
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
        <p class="text-xs text-muted/80 mt-3 pl-1">
          Get 10 free credits or try refining 2 articles without logging in.
        </p>
      </div>

      <!-- Social proof / quick stats -->
      <div class="flex flex-wrap items-center gap-6 mt-14 pt-10 border-t border-border">
        <div>
          <p class="text-2xl font-bold text-text tabular-nums">{cmsExportSuccess}</p>
          <p class="text-xs text-muted mt-0.5">CMS Export Success</p>
        </div>
        <div class="w-px h-8 bg-border"></div>
        <div>
          <p class="text-2xl font-bold text-text tabular-nums">{seoCompletionRate}</p>
          <p class="text-xs text-muted mt-0.5">SEO Packages Completed</p>
        </div>
        <div class="w-px h-8 bg-border"></div>
        <div>
          <p class="text-2xl font-bold text-text tabular-nums">
            {typeof avgProcessTimeMins === "number" ? `${avgProcessTimeMins}m` : "—"}
          </p>
          <p class="text-xs text-muted mt-0.5">Average Process Time</p>
        </div>
        <div class="w-px h-8 bg-border"></div>
        <div class="flex flex-col gap-1">
          <div class="flex items-center gap-2">
            <span class="inline-block w-2 h-2 rounded-full bg-success"></span>
            <p class="text-sm font-medium text-muted">Operational Metrics</p>
          </div>
          {eaiUpdatedAt && (
            <p class="text-[10px] text-muted/80">Updated {eaiUpdatedAt}</p>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
