---
// Ecosystem Preview Section - Interactive visual mockup of EAI & Blog
---

<section id="ecosystem-preview" class="bg-surface">
  <div class="section">
    <div class="text-center mb-14">
      <div class="section-label mx-auto">Interactive Preview</div>
      <h2 class="section-title">Ecosystem in action.</h2>
      <p class="section-subtitle mx-auto text-center">
        See how EAI refines raw drafts and exports publication-ready content directly to Blog Envoyou.
      </p>
    </div>

    <!-- Tabs selector -->
    <div class="flex justify-center mb-10">
      <div class="inline-flex p-1.5 rounded-2xl bg-surface-soft border border-border shadow-sm">
        <button
          id="tab-btn-eai"
          class="tab-btn flex items-center gap-1 px-2.5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-200 cursor-pointer active"
          data-tab="eai"
        >
          <svg class="w-5 h-5" viewBox="0 0 512 512" fill="currentColor">
            <path d="M68.1 88.5c-6.3 14.9-10.2 28.3-12 41-.9 6.1-.7 7.4 1.6 13.9 11.8 32.7 41.9 64.8 86.1 91.3 12.4 7.5 45.1 23.7 45.9 22.9.4-.3.2-.6-.3-.6-1.5 0-22.9-12.5-30.3-17.7-54.7-38.5-84.1-87.7-87-145.7l-.6-13.1z"/>
            <path d="M52.5 151.3c-1.3 9.8.1 37.2 2.3 46.7 5.4 23.1 15.6 44.4 31.5 66 9.3 12.6 34.4 37.4 48.7 48.2 42.9 32.3 97.4 56.2 159.6 70.2 8.9 2 16.9 3.6 17.8 3.6s1.5.3 1.3.8c-.3.4-14.8 10.4-32.2 22.2l-31.7 21.5 55.7.3 55.6.2 32.7-22.1c43.8-29.5 89.6-60.6 95.7-64.8l4.9-3.4-2.4-1.6c-2.6-1.7-78.7-53.2-111.5-75.5l-20-13.6-55.9.2-55.9.3 34.6 23.4c19.1 12.8 34.7 23.4 34.7 23.6 0 .9-41.4-7.1-59.3-11.6-99.5-25-173.3-71.8-199.2-126.4-2.3-5-4.7-10.1-5.2-11.5-.9-2.2-1.1-1.9-1.8 3.3"/>
          </svg>
          EAI Workspace
        </button>
        <button
          id="tab-btn-blog"
          class="tab-btn flex items-center gap-1 px-2.5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-200 cursor-pointer"
          data-tab="blog"
        >
          <svg class="w-5 h-5" viewBox="0 0 512 512" fill="currentColor">
            <path d="M223.2 24.5c-44.7 6.8-85.4 25-119.2 53.3-14.5 12.1-40 40-37.3 40.9.5.2 39.1-6.7 85.8-15.2 46.8-8.6 87.3-16 90-16.5 2.8-.5 18.7-3.4 35.5-6.5s32.5-6 35-6.4c30.6-5.4 68.7-12.6 69.4-13.2 1.2-1-16.6-11.3-30.4-17.5-17.8-8.1-35.3-13.5-57-17.6-13.9-2.6-57.6-3.4-71.8-1.3M430 108.1c-3.1 6.4-9.8 13.2-16.3 16.3-4.1 2-26.2 6.3-106.7 21.1-139.4 25.4-159.8 29.2-172.5 31.5-6 1.2-32.3 6-58.4 10.8l-47.5 8.7-1.3 5c-2.7 10.8-5.4 29.6-6 42.9l-.6 13.8 2.9-.6c1.6-.3 12.3-2.2 23.9-4.1 44.2-7.5 91.9-15.6 114-19.4 12.7-2.2 36.3-6.2 52.5-9s40.1-6.8 53-9c20.7-3.6 56.5-9.5 62.8-10.5 1.2-.2 4.5.1 7.4.6 19.6 3.6 32.3 22.8 27.4 41.6-1.9 7.4-4.9 12.4-10.6 17.6-6.8 6.1-10.6 7.5-30 10.6-5.1.8-34.2 5.8-96.5 16.4-40.2 6.9-94.6 16.2-132.5 22.6-48.8 8.3-63.2 10.9-63.6 11.2-.4.4 4.8 15.1 8.1 22.8 7.4 17.5 19 37.3 21.4 36.6.9-.3 3.2-.7 5.1-1.1 5.5-.8 53.8-9.2 148-25.6 35.8-6.2 47.9-8 52.6-7.6 12.2.9 23 8.4 28.3 19.7 2.2 4.7 2.6 6.9 2.6 14.5 0 8.4-.2 9.5-3.4 15.3-1.9 3.5-5.3 7.9-7.5 9.9-7.5 6.5-9.5 7.1-54.6 14.8-8.5 1.5-20.2 3.5-26 4.5s-16.1 2.8-23 4-17.2 3-23 4c-5.8 1.1-17.8 3.1-26.8 4.6-8.9 1.5-16.2 3-16.2 3.4 0 1.2 19.3 13.4 30.3 19.1 25.3 13.1 52.5 21.4 81.7 24.9 19.8 2.4 53.7.8 74.3-3.5 75.9-15.8 141-70.4 169.5-142.5 18.5-46.6 21.7-95.6 9.6-145-7.9-31.9-25.4-66.3-47-92.1l-3.1-3.8z"/>
          </svg>
          Blog Envoyou
        </button>
      </div>
    </div>

    <!-- Preview Windows -->
    <div class="relative max-w-5xl mx-auto">
      <!-- Background glows -->
      <div class="absolute -inset-4 bg-gradient-to-r from-primary/10 to-accent/10 rounded-[32px] blur-2xl opacity-70 pointer-events-none"></div>

      <!-- Window Container -->
      <div class="relative card min-h-[550px] flex flex-col shadow-2xl border-border overflow-hidden bg-surface">
        <!-- Window Titlebar -->
        <div class="flex items-center justify-between px-5 py-3 border-b border-border bg-surface-soft select-none">
          <div class="flex items-center gap-2">
            <span class="w-3.5 h-3.5 rounded-full bg-rose-500/80"></span>
            <span class="w-3.5 h-3.5 rounded-full bg-amber-500/80"></span>
            <span class="w-3.5 h-3.5 rounded-full bg-emerald-500/80"></span>
          </div>
          <span id="window-title" class="text-xs font-mono text-muted font-medium">envoyou-eai-workspace v0.26.1</span>
          <div class="w-12"></div> <!-- Spacer for center alignment -->
        </div>

        <!-- TAB 1: EAI WORKSPACE CONTENT -->
        <div id="tab-content-eai" class="tab-pane active flex flex-1 flex-col lg:flex-row min-w-0">
          <!-- EAI Activity Bar (Left Sidebar Mock) -->
          <div class="hidden sm:flex flex-col items-center gap-5 px-3 py-6 border-r border-border bg-surface-soft/50">
            <div class="w-8 h-8 rounded-lg bg-primary/10 text-primary flex items-center justify-center">
              <svg class="w-4.5 h-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            </div>
            <div class="w-8 h-8 rounded-lg text-muted hover:text-text flex items-center justify-center transition-colors">
              <svg class="w-4.5 h-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
            </div>
            <div class="w-8 h-8 rounded-lg text-muted hover:text-text flex items-center justify-center transition-colors">
              <svg class="w-4.5 h-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
            </div>
            <div class="mt-auto w-8 h-8 rounded-lg text-muted hover:text-text flex items-center justify-center transition-colors">
              <svg class="w-4.5 h-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            </div>
          </div>

          <!-- Main workspace panels -->
          <div class="flex-1 grid grid-cols-1 lg:grid-cols-3 min-w-0">
            <!-- Center panel: Before & After Split -->
            <div class="lg:col-span-2 flex flex-col border-b lg:border-b-0 lg:border-r border-border min-w-0">
              <!-- Top tab headers -->
              <div class="flex items-center border-b border-border bg-surface-soft/30 px-4 py-2">
                <span class="text-xs font-mono text-muted">Active Draft: </span>
                <span class="text-xs font-mono text-text ml-1.5 font-semibold">seo-performance.md</span>
                <span class="w-1.5 h-1.5 rounded-full bg-primary ml-2 animate-pulse"></span>
              </div>

              <!-- Content Areas -->
              <div class="flex-1 grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-border min-h-[300px]">
                <!-- Raw Input -->
                <div class="p-5 flex flex-col min-w-0">
                  <div class="flex items-center justify-between mb-3">
                    <span class="text-[10px] font-bold uppercase tracking-wider text-muted">Raw Input Draft</span>
                    <span class="text-[10px] font-mono text-amber-500 bg-amber-500/10 px-2 py-0.5 rounded border border-amber-500/20 font-semibold">Needs Review</span>
                  </div>
                  <div class="flex-1 text-xs font-mono text-muted leading-6 space-y-4 overflow-y-auto max-h-[320px] select-none">
                    <p>
                      seo is very important. we need to optimize our landing hub for maximum performance. <span class="border-b-2 border-dashed border-rose-500 text-text bg-rose-500/10">stats show that 90% of traffic comes from search engines</span>. this is backed by Google research from 2025.
                    </p>
                    <p>
                      we also need a fast platform for blog articles. editors want full control of publishing workflows.
                    </p>
                  </div>
                </div>

                <!-- EAI Refined Output -->
                <div class="p-5 flex flex-col min-w-0 bg-surface-soft/10">
                  <div class="flex items-center justify-between mb-3">
                    <span class="text-[10px] font-bold uppercase tracking-wider text-primary">EAI Refined Output</span>
                    <span class="text-[10px] font-mono text-emerald-500 bg-emerald-500/10 px-2 py-0.5 rounded border border-emerald-500/20 font-semibold">Verified Ready</span>
                  </div>
                  <div class="flex-1 text-xs text-text leading-relaxed space-y-4 overflow-y-auto max-h-[320px] select-none">
                    <p>
                      <strong>Search Engine Optimization (SEO)</strong> remains a critical driver for digital growth. By optimizing our landing hub, we ensure high performance and discoverability. <span class="bg-primary/10 border-b border-primary/30 px-1 py-0.5 rounded">According to Google's 2026 Search Report, search engines drive over 90% of web traffic</span>.
                    </p>
                    <p>
                      In addition, the platform offers a premium blog publishing ecosystem, equipping editorial teams with full control over sitemaps and content workflows.
                    </p>
                  </div>
                </div>
              </div>

              <!-- Pipeline Status Bar (Matches EAI) -->
              <div class="border-t border-border bg-surface-soft/40 p-4">
                <div class="flex items-center justify-between mb-2">
                  <div class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-primary animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <circle cx="12" cy="12" r="10" stroke-opacity="0.25"/><path d="M12 2v4"/>
                    </svg>
                    <span class="text-xs font-semibold text-text">Quality and source checks</span>
                  </div>
                  <span class="text-[10px] font-mono text-muted">Processing: 4.8s</span>
                </div>
                <!-- Progress Line -->
                <div class="h-1 rounded-full bg-border overflow-hidden">
                  <div class="h-full bg-primary transition-all duration-1000" style="width: 65%;"></div>
                </div>
              </div>
            </div>

            <!-- Right panel: Quality Gate & Feedback (Matches EAI UI) -->
            <div class="p-5 flex flex-col bg-surface-soft/30 min-w-0">
              <h3 class="text-xs font-bold uppercase tracking-wider text-text mb-4 pb-2 border-b border-border">Quality Gate</h3>

              <!-- Readiness Badge -->
              <div class="mb-4">
                <p class="text-[10px] text-muted font-semibold mb-1.5 uppercase">Readiness Verdict</p>
                <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border border-emerald-500/20 bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 font-bold text-xs">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                  READY TO EXPORT
                </div>
              </div>

              <!-- Claims Checklist -->
              <div class="flex-1 space-y-3">
                <p class="text-[10px] text-muted font-semibold uppercase">Source Claims Validation</p>

                <!-- Claim Item 1 (Source Backed) -->
                <div class="p-3 rounded-xl border border-border bg-surface shadow-sm">
                  <div class="flex items-center justify-between gap-2 mb-1.5">
                    <span class="text-[10px] font-bold text-text truncate">"90% of traffic"</span>
                    <span class="text-[9px] font-mono px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 font-bold uppercase border border-emerald-500/10">Source Backed</span>
                  </div>
                  <p class="text-[10px] text-muted leading-relaxed">Verified via Google Search Report 2026 reference.</p>
                </div>

                <!-- Claim Item 2 (Needs Citation) -->
                <div class="p-3 rounded-xl border border-border bg-surface shadow-sm">
                  <div class="flex items-center justify-between gap-2 mb-1.5">
                    <span class="text-[10px] font-bold text-text truncate">"Google research 2026"</span>
                    <span class="text-[9px] font-mono px-2 py-0.5 rounded-full bg-amber-500/10 text-amber-600 dark:text-amber-400 font-bold uppercase border border-amber-500/10">Needs Citation</span>
                  </div>
                  <p class="text-[10px] text-muted leading-relaxed">Source document linked. Auto-formatting citations.</p>
                </div>
              </div>

              <!-- Export button mockup -->
              <button class="mt-4 w-full py-2.5 px-4 rounded-xl bg-gradient-to-r from-primary to-primary-deep text-white text-xs font-bold shadow-md hover:brightness-105 transition-all flex items-center justify-center gap-1.5 cursor-pointer">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8M16 6l-4-4-4 4M12 2v13"/>
                </svg>
                Export to Blog Envoyou
              </button>
            </div>
          </div>
        </div>

        <!-- TAB 2: BLOG ENVOYOU CONTENT -->
        <div id="tab-content-blog" class="tab-pane hidden flex flex-1 flex-col min-w-0 bg-surface">
          <!-- Browser Address bar mock -->
          <div class="flex items-center gap-3 px-4 py-2 border-b border-border bg-surface-soft/40">
            <!-- Navigation buttons -->
            <div class="flex items-center gap-1.5 shrink-0 text-muted">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7"/></svg>
              <svg class="w-3.5 h-3.5 opacity-40" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 1 1 21.2 9H18"/></svg>
            </div>
            <!-- Address input -->
            <div class="flex-1 bg-surface border border-border rounded-lg px-3 py-1 flex items-center gap-2 min-w-0">
              <svg class="w-3 h-3 text-emerald-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
              <span class="text-xs font-mono text-muted truncate">blog.envoyou.com/posts/publishing-intelligence-seo</span>
            </div>
          </div>

          <!-- Blog Layout split -->
          <div class="flex-1 grid grid-cols-1 lg:grid-cols-3 min-w-0 divide-y lg:divide-y-0 lg:divide-x divide-border">
            <!-- Left 2 Cols: Main Published Post Reading View -->
            <div class="lg:col-span-2 p-6 overflow-y-auto max-h-[400px] min-w-0">
              <!-- Article header -->
              <div class="flex flex-wrap items-center gap-3 mb-4">
                <span class="text-xs font-bold uppercase tracking-wider text-primary bg-primary/10 px-2.5 py-1 rounded-full">Engineering</span>
                <span class="text-xs text-muted font-medium flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  4 min read
                </span>
              </div>

              <!-- Title -->
              <h1 class="text-2xl sm:text-3xl font-extrabold text-text tracking-tight leading-tight mb-5">
                Publishing Intelligence: Optimizing Landing Hubs for SEO
              </h1>

              <!-- Author card -->
              <div class="flex items-center gap-3 mb-6 pb-6 border-b border-border">
                <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-sm">
                  E
                </div>
                <div>
                  <p class="text-xs font-bold text-text">Envoyou Team</p>
                  <p class="text-[10px] text-muted mt-0.5">Published on June 11, 2026</p>
                </div>
              </div>

              <!-- Reading body text -->
              <div class="text-sm text-text/90 leading-7 space-y-4">
                <p class="text-base font-medium text-text leading-relaxed">
                  Search Engine Optimization (SEO) remains a critical driver for digital growth. By optimizing our landing hub, we ensure high performance and discoverability. According to Google's 2026 Search Report, search engines drive over 90% of web traffic.
                </p>
                <blockquote class="border-l-4 border-primary bg-surface-soft p-4 rounded-r-xl italic my-6 text-text">
                  "Search engines drive over 90% of web traffic, making performance optimization a necessity rather than an option."
                </blockquote>
                <p>
                  In addition, the platform offers a premium blog publishing ecosystem, equipping editorial teams with full control over sitemaps and content workflows.
                </p>
              </div>
            </div>

            <!-- Right Col: SEO Preview Card (Simulates Google Search result snippet) -->
            <div class="p-6 bg-surface-soft/30 flex flex-col justify-center min-w-0">
              <h3 class="text-xs font-bold uppercase tracking-wider text-text mb-4 pb-2 border-b border-border">SEO Snippet Preview</h3>

              <!-- Google Search Snippet UI Mockup -->
              <div class="p-4 rounded-xl border border-border bg-surface shadow-sm select-none">
                <!-- Search Result Header -->
                <div class="flex items-center gap-2 mb-1.5">
                  <div class="w-6 h-6 rounded-full bg-surface-soft flex items-center justify-center border border-border">
                    <!-- Mini Logo -->
                    <svg class="w-3.5 h-3.5 text-primary" viewBox="0 0 512 512">
                      <g fill="currentColor">
                        <path d="M222 7.5c-44.3 5.9-84.2 22.3-120.8 49.7-15.1 11.3-36.8 33.4-50.3 51.4-.9 1.2-4.7 1.8 76.6-13.1 87-15.9 105.8-19.4 169-31 31.9-5.9 66-12.1 75.8-13.9 9.8-1.7 17.8-3.6 17.8-4.1-.1-2.6-32.5-19.3-50.2-25.9-12.3-4.5-33.4-10-47.4-12.1-14.9-2.4-55.9-2.9-70.5-1M441.6 96.8c-2.8 6.8-12.7 16.3-19.6 18.9-3 1.1-20.6 4.8-39 8.2-18.4 3.3-45.9 8.3-61 11.1s-48.2 8.9-73.5 13.5C46.3 185.6 11.6 192 11 192.7c-1.1 1.2-4.9 20.4-6.5 32.8-.8 6-1.5 15.9-1.5 21.8v10.9l2.7-.6c1.6-.3 35-6 74.3-12.6 39.3-6.7 80.3-13.6 91-15.5 93.6-16.4 163-27.7 168.1-27.2 8.3.7 16.9 5 22.9 11.3 7.7 8.1 9.5 12.8 9.5 24.9 0 8.8-.3 10.7-2.7 15.7-3.4 7.3-10.4 14.3-17.4 17.5-5.5 2.5-7.7 2.9-97.9 18.3-29.1 4.9-207.5 35.4-225.3 38.4-7.3 1.3-13.5 2.6-13.9 2.9-.8.9 4.8 16.8 10.4 29.1 4.1 9.2 14.5 28.5 17.8 32.9 1.4 2-5.7 3.1 141-22.4 67.2-11.7 76.1-13.1 82.5-12.7 12.8.7 24.4 8.7 30.2 20.7 2.9 5.9 3.2 7.5 3.2 15.1-.1 19-11.3 32.6-30.1 36.5-3.8.8-21.4 3.9-39.3 7s-44.2 7.6-58.5 10.1-35 6-45.9 7.9-20.1 3.6-20.3 3.9c-.9.9 21.7 14.9 34.7 21.5 24.1 12.2 49.8 20.6 76.3 24.8 14.1 2.2 58.4 2.5 71.7.5 21.2-3.3 39.8-8.2 57-14.9 77.7-30.5 135.7-97.7 153.8-178.3 5-22.2 5.7-29.4 5.7-56.5 0-27.3-1.2-37.5-6.5-59.3-8.4-34.4-25.3-69-47.2-96.5-3.8-4.8-7-8.7-7.1-8.7s-1.1 2.1-2.1 4.8"/>
                      </g>
                    </svg>
                  </div>
                  <div class="min-w-0">
                    <p class="text-[10px] text-text font-semibold truncate leading-none">Envoyou Blog</p>
                    <p class="text-[9px] text-muted font-mono truncate mt-0.5">https://blog.envoyou.com › posts</p>
                  </div>
                </div>

                <!-- Google blue title link -->
                <h4 class="text-sm font-semibold text-blue-600 dark:text-blue-400 hover:underline leading-tight mb-1">
                  Publishing Intelligence: Optimizing Landing Hubs for SEO
                </h4>

                <!-- Google description -->
