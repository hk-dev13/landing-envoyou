---
// Products showcase section
---

<section id="products">
  <div class="section">
    <div class="text-center mb-14">
      <div class="section-label mx-auto">Our Products</div>
      <h2 class="section-title">Two products,<br />one publishing ecosystem.</h2>
      <p class="section-subtitle mx-auto text-center">
        E-Blog and EAI work together as a connected content workflow — from editorial creation to publication and audience growth.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- E-Blog Card -->
      <div class="card group">
        <!-- Card header with gradient -->
        <div
          class="relative p-8 pb-6 overflow-hidden"
          style="background: radial-gradient(circle at 20% 0%, rgba(11,121,194,0.15) 0%, transparent 55%), radial-gradient(circle at 80% 80%, rgba(14,165,233,0.08) 0%, transparent 45%);"
        >
          <div class="flex items-start justify-between mb-6">
            <div class="w-12 h-12 rounded-2xl border border-border bg-surface flex items-center justify-center">
              <svg class="w-7 h-7" viewBox="0 0 512 512">
                <path fill="#0b79c2" d="M223.2 24.5c-44.7 6.8-85.4 25-119.2 53.3-14.5 12.1-40 40-37.3 40.9.5.2 39.1-6.7 85.8-15.2 46.8-8.6 87.3-16 90-16.5 2.8-.5 18.7-3.4 35.5-6.5s32.5-6 35-6.4c30.6-5.4 68.7-12.6 69.4-13.2 1.2-1-16.6-11.3-30.4-17.5-17.8-8.1-35.3-13.5-57-17.6-13.9-2.6-57.6-3.4-71.8-1.3M430 108.1c-3.1 6.4-9.8 13.2-16.3 16.3-4.1 2-26.2 6.3-106.7 21.1-139.4 25.4-159.8 29.2-172.5 31.5-6 1.2-32.3 6-58.4 10.8l-47.5 8.7-1.3 5c-2.7 10.8-5.4 29.6-6 42.9l-.6 13.8 2.9-.6c1.6-.3 12.3-2.2 23.9-4.1 44.2-7.5 91.9-15.6 114-19.4 12.7-2.2 36.3-6.2 52.5-9s40.1-6.8 53-9c20.7-3.6 56.5-9.5 62.8-10.5 1.2-.2 4.5.1 7.4.6 19.6 3.6 32.3 22.8 27.4 41.6-1.9 7.4-4.9 12.4-10.6 17.6-6.8 6.1-10.6 7.5-30 10.6-5.1.8-34.2 5.8-96.5 16.4-40.2 6.9-94.6 16.2-132.5 22.6-48.8 8.3-63.2 10.9-63.6 11.2-.4.4 4.8 15.1 8.1 22.8 7.4 17.5 19 37.3 21.4 36.6.9-.3 3.2-.7 5.1-1.1 5.5-.8 53.8-9.2 148-25.6 35.8-6.2 47.9-8 52.6-7.6 12.2.9 23 8.4 28.3 19.7 2.2 4.7 2.6 6.9 2.6 14.5 0 8.4-.2 9.5-3.4 15.3-1.9 3.5-5.3 7.9-7.5 9.9-7.5 6.5-9.5 7.1-54.6 14.8-8.5 1.5-20.2 3.5-26 4.5s-16.1 2.8-23 4-17.2 3-23 4c-5.8 1.1-17.8 3.1-26.8 4.6-8.9 1.5-16.2 3-16.2 3.4 0 1.2 19.3 13.4 30.3 19.1 25.3 13.1 52.5 21.4 81.7 24.9 19.8 2.4 53.7.8 74.3-3.5 75.9-15.8 141-70.4 169.5-142.5 18.5-46.6 21.7-95.6 9.6-145-7.9-31.9-25.4-66.3-47-92.1l-3.1-3.8z"/>
              </svg>
            </div>
            <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-emerald-700 dark:text-emerald-400 bg-emerald-100 dark:bg-emerald-900/40 px-3 py-1 rounded-full border border-emerald-300/60 dark:border-emerald-700/50">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
              Live
            </span>
          </div>

          <h3 class="text-2xl font-bold text-text tracking-tight">E-Blog</h3>
          <p class="text-sm text-muted mt-2 leading-6">
            A modern publishing platform for Envoyou articles, built with a clean reading experience, structured content management, and SEO-focused publishing tools.
          </p>
        </div>

        <!-- Card body -->
        <div class="px-8 pb-8 pt-4 border-t border-border">
          <ul class="space-y-2.5 mb-8">
            {[
              "Clean reading experience for published articles",
              "Admin dashboard for content management",
              "Author, category, and tag organization",
              "SEO-ready pages with sitemap support",
              "Analytics and moderation workflows",
            ].map((feature) => (
              <li class="flex items-center gap-2.5 text-sm text-muted">
                <svg class="w-4 h-4 shrink-0 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                {feature}
              </li>
            ))}
          </ul>

          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href="https://blog.envoyou.com"
              target="_blank"
              rel="noopener noreferrer"
              id="product-blog-cta"
              class="btn-primary text-sm py-2.5 px-5 flex-1 justify-center"
            >
              Read the Blog
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M7 17L17 7M17 7H7M17 7v10"/>
              </svg>
            </a>
            <div class="flex items-center gap-2 px-4 py-2.5 rounded-full border border-border bg-surface-soft">
              <svg class="w-3.5 h-3.5 text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
              </svg>
              <span class="text-xs font-mono text-muted">blog.envoyou.com</span>
            </div>
          </div>
        </div>
      </div>

      <!-- EAI Card -->
      <div class="card group">
        <!-- Card header with gradient -->
        <div
          class="relative p-8 pb-6 overflow-hidden"
          style="background: radial-gradient(circle at 20% 0%, rgba(14,165,233,0.12) 0%, transparent 55%), radial-gradient(circle at 80% 80%, rgba(16,185,129,0.07) 0%, transparent 45%);"
        >
          <div class="flex items-start justify-between mb-6">
            <div class="w-12 h-12 rounded-2xl border border-border bg-surface flex items-center justify-center">
              <svg class="w-7 h-7" viewBox="0 0 512 512">
                <path fill="#0b79c2" d="M68.1 88.5c-6.3 14.9-10.2 28.3-12 41-.9 6.1-.7 7.4 1.6 13.9 11.8 32.7 41.9 64.8 86.1 91.3 12.4 7.5 45.1 23.7 45.9 22.9.4-.3.2-.6-.3-.6-1.5 0-22.9-12.5-30.3-17.7-54.7-38.5-84.1-87.7-87-145.7l-.6-13.1z"/>
                <path fill="#0b79c2" d="M52.5 151.3c-1.3 9.8.1 37.2 2.3 46.7 5.4 23.1 15.6 44.4 31.5 66 9.3 12.6 34.4 37.4 48.7 48.2 42.9 32.3 97.4 56.2 159.6 70.2 8.9 2 16.9 3.6 17.8 3.6s1.5.3 1.3.8c-.3.4-14.8 10.4-32.2 22.2l-31.7 21.5 55.7.3 55.6.2 32.7-22.1c43.8-29.5 89.6-60.6 95.7-64.8l4.9-3.4-2.4-1.6c-2.6-1.7-78.7-53.2-111.5-75.5l-20-13.6-55.9.2-55.9.3 34.6 23.4c19.1 12.8 34.7 23.4 34.7 23.6 0 .9-41.4-7.1-59.3-11.6-99.5-25-173.3-71.8-199.2-126.4-2.3-5-4.7-10.1-5.2-11.5-.9-2.2-1.1-1.9-1.8 3.3"/>
              </svg>
            </div>
            <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-emerald-700 dark:text-emerald-400 bg-emerald-100 dark:bg-emerald-900/40 px-3 py-1 rounded-full border border-emerald-300/60 dark:border-emerald-700/50">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
              Live
            </span>
          </div>

          <h3 class="text-2xl font-bold text-text tracking-tight">EAI Editorial Intelligence</h3>
          <p class="text-sm text-muted mt-2 leading-6">
            An editorial intelligence workspace that helps transform raw drafts into publication-ready articles through structured refinement, source fidelity checks, and quality validation.
          </p>
        </div>

        <!-- Card body -->
        <div class="px-8 pb-8 pt-4 border-t border-border">
          <ul class="space-y-2.5 mb-8">
            {[
              "Raw draft refinement workflow",
              "Publication readiness quality gate",
              "Source fidelity and formatting validation",
              "Editorial analytics and history tracking",
              "Connected export flow to E-Blog",
            ].map((feature) => (
              <li class="flex items-center gap-2.5 text-sm text-muted">
                <svg class="w-4 h-4 shrink-0 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                {feature}
              </li>
            ))}
          </ul>

          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href="https://eai.envoyou.com"
              target="_blank"
              rel="noopener noreferrer"
              id="product-eai-cta"
              class="btn-primary text-sm py-2.5 px-5 flex-1 justify-center"
            >
              Try EAI
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M7 17L17 7M17 7H7M17 7v10"/>
              </svg>
            </a>
            <div class="flex items-center gap-2 px-4 py-2.5 rounded-full border border-border bg-surface-soft">
              <svg class="w-3.5 h-3.5 text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
              </svg>
              <span class="text-xs font-mono text-muted">eai.envoyou.com</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
