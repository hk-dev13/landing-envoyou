---
// Products showcase section
---

<section id="products">
  <div class="section">
    <div class="text-center mb-14">
      <div class="section-label mx-auto">Core Platform</div>
      <h2 class="section-title">EAI: The Editorial Intelligence Workspace</h2>
      <p class="section-subtitle mx-auto text-center">
        Our product designed to automate, verify, and scale professional content operations.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- EAI Card (Featured - 2/3 Width) -->
      <div class="card group lg:col-span-2 flex flex-col justify-between">
        <!-- Card header with gradient -->
        <div
          class="relative p-8 pb-6 overflow-hidden"
          style="background: radial-gradient(circle at 20% 0%, rgba(14,165,233,0.15) 0%, transparent 55%), radial-gradient(circle at 80% 80%, rgba(16,185,129,0.08) 0%, transparent 45%);"
        >
          <div class="flex items-start justify-between mb-6">
            <div class="w-12 h-12 rounded-2xl border border-border bg-surface flex items-center justify-center">
              <svg class="w-9 h-9" viewBox="0 0 500 500" fill="#0b79c2">
                <path d="M296.5 166.6c-6.4 3.3-6.4 3.3-36.25 56.25C221.6 291.55 199 332.4 199 333.7c0 1.85 28 1.75 33.3-.15 6.7-2.4 9.6-6.65 31.75-46.55 15.35-27.8 36.95-65.3 38.4-66.85 1.1-1.1 2.15.1 6.3 7C317.4 241.7 333 270.1 333 271.35c0 .35-5.3.65-11.85.65-18.45 0-22.4 1.1-29.75 8.45-5.5 5.45-16 21.25-14.9 22.4.25.25 16.95.7 37.1 1.05l36.65.6 3.8 6.5c13.8 23.55 13 23 35.6 23 9.55 0 17.35-.35 17.35-.75s-1-2.35-2.15-4.25c-2.4-3.85-8.45-14.8-37.85-68.5-19-34.7-31.35-57.15-41.7-75.8-10.2-18.35-18.4-23.55-28.8-18.1m-197 4.4c-21.65 2.35-40.7 19.3-44.4 39.45-1.4 7.65-1.45 76.8-.05 85.4 2.35 14.4 12.9 27.45 28.1 34.8 7.05 3.45 17.6 4.25 56.85 4.3l30.5.05 5.1-2.95c7.25-4.15 23.4-24.45 23.4-29.4 0-.3-22.85-.65-50.8-.85-62.8-.35-58.65 1.15-59.35-21.8l-.35-11.5 43.35-.5 43.35-.5 2.75-3.3c3.2-3.8 14.95-24.05 15.75-27.1l.55-2.1H87.7l.65-6.75c.35-3.7.65-8.5.65-10.65 0-3.2.7-4.6 4.25-8.1l4.25-4.25 56.7-.75 56.75-.75 8.85-16.1 8.85-16.15-2.55-.75c-3.1-.9-117.95-.65-126.6.25m320.35 3.55c-13.2 4.15-17.8 21.6-8.5 32.15 8.25 9.45 21.15 9.7 29.95.65 14.75-15.2-1-39.3-21.45-32.8M411 275.75c0 36.8.15 41.1 1.75 44.2 3.45 6.85 15.2 13.3 26.6 14.65l5.35.65.6-32.45c.35-17.85.35-40.4 0-50.15l-.6-17.65H411z"/>
</svg>
            </div>
            <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-primary bg-primary/10 px-3 py-1 rounded-full border border-primary/20">
              Flagship Product
            </span>
          </div>

          <h3 class="text-2xl font-bold text-text tracking-tight">Envoyou AI Editorial Intelligence</h3>
          <p class="text-sm text-muted mt-2 leading-6">
            An editorial workspace designed to automate draft refinement, enforce strict fact-checking policies, optimize SEO, and connect seamlessly to your custom publishing pipelines.
          </p>
        </div>

        <!-- EAI 3 Production Pillars -->
        <div class="px-8 py-6 border-t border-border bg-surface/50">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Pillar 1 -->
            <div class="flex flex-col">
              <div class="flex items-center gap-2 mb-2">
                <span class="w-2 h-2 rounded-full bg-primary"></span>
                <h4 class="text-sm font-bold text-text">1-Click Editorial Polish</h4>
              </div>
              <p class="text-xs text-muted leading-relaxed">
                Instantly refine raw drafts or topic ideas. Features a dedicated <strong>Press Release Mode</strong> to strip marketing hype and corporate buzzwords into objective, ready-to-publish news copy.
              </p>
            </div>

            <!-- Pillar 2 -->
            <div class="flex flex-col">
              <div class="flex items-center gap-2 mb-2">
                <span class="w-2 h-2 rounded-full bg-primary"></span>
                <h4 class="text-sm font-bold text-text">Quality Gate & Verification</h4>
              </div>
              <p class="text-xs text-muted leading-relaxed mb-2">
                Enforces strict source fidelity checks. Keeps fact-checking interactive with real-time UI readiness verdicts:
              </p>
              <div class="flex flex-wrap gap-1.5 mt-auto">
                <span class="inline-flex items-center text-[9px] font-bold px-1.5 py-0.5 rounded bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-500/20">READY</span>
                <span class="inline-flex items-center text-[9px] font-bold px-1.5 py-0.5 rounded bg-amber-500/10 text-amber-600 dark:text-amber-400 border border-amber-500/20">NEEDS REVIEW</span>
                <span class="inline-flex items-center text-[9px] font-bold px-1.5 py-0.5 rounded bg-rose-500/10 text-rose-600 dark:text-rose-400 border border-rose-500/20">BLOCKED</span>
              </div>
            </div>

            <!-- Pillar 3 -->
            <div class="flex flex-col">
              <div class="flex items-center gap-2 mb-2">
                <span class="w-2 h-2 rounded-full bg-primary"></span>
                <h4 class="text-sm font-bold text-text">Secure CMS Export</h4>
              </div>
              <p class="text-xs text-muted leading-relaxed">
                Connect EAI to your existing publishing infrastructure. Export finalized drafts, cover images, and structured SEO packages directly to external CMS platforms via secure AES-256-GCM encryption.
              </p>
            </div>
          </div>
        </div>

        <!-- EAI Footer CTA -->
        <div class="px-8 pb-8 pt-4 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-4 bg-surface-soft/20">
          <div class="flex items-center gap-2">
            <svg class="w-3.5 h-3.5 text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
            </svg>
            <span class="text-xs font-mono text-muted">eai.envoyou.com</span>
          </div>
          <a
            href="#tally-open=ODy5xM&tally-emoji-text=👋&tally-emoji-animation=wave&ref=products"
            id="product-eai-cta"
            class="btn-primary text-sm py-2.5 px-6"
          >
            Request Beta Access
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M7 17L17 7M17 7H7M17 7v10"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- E-Blog Card (Proof of Concept - 1/3 Width) -->
      <div class="card group lg:col-span-1 flex flex-col justify-between">
        <!-- Card header with gradient -->
        <div
          class="relative p-8 pb-6 overflow-hidden flex-1"
          style="background: radial-gradient(circle at 20% 0%, rgba(11,121,194,0.12) 0%, transparent 55%), radial-gradient(circle at 80% 80%, rgba(14,165,233,0.06) 0%, transparent 45%);"
        >
          <div class="flex items-start justify-between mb-6">
            <div class="w-12 h-12 rounded-2xl border border-border bg-surface flex items-center justify-center">
              <svg class="w-7 h-7" viewBox="0 0 512 512">
                <path fill="#0b79c2" d="M223.2 24.5c-44.7 6.8-85.4 25-119.2 53.3-14.5 12.1-40 40-37.3 40.9.5.2 39.1-6.7 85.8-15.2 46.8-8.6 87.3-16 90-16.5 2.8-.5 18.7-3.4 35.5-6.5s32.5-6 35-6.4c30.6-5.4 68.7-12.6 69.4-13.2 1.2-1-16.6-11.3-30.4-17.5-17.8-8.1-35.3-13.5-57-17.6-13.9-2.6-57.6-3.4-71.8-1.3M430 108.1c-3.1 6.4-9.8 13.2-16.3 16.3-4.1 2-26.2 6.3-106.7 21.1-139.4 25.4-159.8 29.2-172.5 31.5-6 1.2-32.3 6-58.4 10.8l-47.5 8.7-1.3 5c-2.7 10.8-5.4 29.6-6 42.9l-.6 13.8 2.9-.6c1.6-.3 12.3-2.2 23.9-4.1 44.2-7.5 91.9-15.6 114-19.4 12.7-2.2 36.3-6.2 52.5-9s40.1-6.8 53-9c20.7-3.6 56.5-9.5 62.8-10.5 1.2-.2 4.5.1 7.4.6 19.6 3.6 32.3 22.8 27.4 41.6-1.9 7.4-4.9 12.4-10.6 17.6-6.8 6.1-10.6 7.5-30 10.6-5.1.8-34.2 5.8-96.5 16.4-40.2 6.9-94.6 16.2-132.5 22.6-48.8 8.3-63.2 10.9-63.6 11.2-.4.4 4.8 15.1 8.1 22.8 7.4 17.5 19 37.3 21.4 36.6.9-.3 3.2-.7 5.1-1.1 5.5-.8 53.8-9.2 148-25.6 35.8-6.2 47.9-8 52.6-7.6 12.2.9 23 8.4 28.3 19.7 2.2 4.7 2.6 6.9 2.6 14.5 0 8.4-.2 9.5-3.4 15.3-1.9 3.5-5.3 7.9-7.5 9.9-7.5 6.5-9.5 7.1-54.6 14.8-8.5 1.5-20.2 3.5-26 4.5s-16.1 2.8-23 4-17.2 3-23 4c-5.8 1.1-17.8 3.1-26.8 4.6-8.9 1.5-16.2 3-16.2 3.4 0 1.2 19.3 13.4 30.3 19.1 25.3 13.1 52.5 21.4 81.7 24.9 19.8 2.4 53.7.8 74.3-3.5 75.9-15.8 141-70.4 169.5-142.5 18.5-46.6 21.7-95.6 9.6-145-7.9-31.9-25.4-66.3-47-92.1l-3.1-3.8z"/>
              </svg>
            </div>
            <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-muted bg-surface-soft px-3 py-1 rounded-full border border-border">
              Case Study / POC
            </span>
          </div>

          <h3 class="text-2xl font-bold text-text tracking-tight">E-Blog</h3>
          <p class="text-sm text-muted mt-2 leading-6">
            An internal proof-of-concept showcase platform demonstrating how EAI automates the publishing flow from draft to public reading experience.
          </p>
          
          <ul class="space-y-2 mt-6">
            {[
              "Clean reading experience",
              "Automated sitemap & SEO output",
              "Powered entirely by EAI exports",
            ].map((feature) => (
              <li class="flex items-center gap-2 text-xs text-muted">
                <svg class="w-3.5 h-3.5 shrink-0 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                {feature}
              </li>
            ))}
          </ul>
        </div>

        <!-- E-Blog Footer CTA -->
        <div class="px-8 pb-8 pt-4 border-t border-border bg-surface-soft/20">
          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href="https://blog.envoyou.com"
              target="_blank"
              rel="noopener noreferrer"
              id="product-blog-cta"
              class="btn-secondary text-sm py-2.5 px-5 flex-1 justify-center"
            >
              Read the Blog
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M7 17L17 7M17 7H7M17 7v10"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</section>
