---
const capabilities = [
  {
    number: "01",
    title: "Refine with editorial control",
    description: "Apply the active brand, audience, tone, structure, language, SEO, and source policies instead of relying on a generic rewrite prompt.",
    detail: "Editorial profiles are versioned per organization.",
  },
  {
    number: "02",
    title: "Review claims and readiness",
    description: "Compare the final draft with its source material, surface source-sensitive feedback, and return a clear Ready, Needs review, or Blocked verdict.",
    detail: "Critical feedback prevents CMS export.",
  },
  {
    number: "03",
    title: "Prepare the publication package",
    description: "Generate the title, slug, excerpt, meta title, meta description, tags, and cover-image guidance alongside the final article.",
    detail: "Publication fields are checked as one contract.",
  },
];
---

<section id="products" data-scroll-section>
  <div class="section">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
      <div class="lg:col-span-4">
        <div class="section-label">EAI Editorial Workspace</div>
        <h2 class="section-title">One product for the work between a draft and publication.</h2>
        <p class="section-subtitle">
          EAI is Envoyou’s commercial platform. It combines drafting support, editorial refinement, SEO preparation, Quality Gate feedback, history, analytics, and controlled export in a tenant-aware workspace.
        </p>
        <a
          href="https://eai.envoyou.com/login"
          data-analytics-event="eai_login_clicked"
          data-analytics-location="homepage_product"
          class="btn-secondary mt-8"
        >
          Open EAI
        </a>
      </div>

      <div class="lg:col-span-8 grid grid-cols-1 gap-5">
        {capabilities.map((capability) => (
          <article class="card p-7 md:p-8 grid grid-cols-[auto_1fr] gap-5 md:gap-7">
            <span class="text-sm font-black font-mono text-primary">{capability.number}</span>
            <div>
              <h3 class="text-xl font-bold text-text">{capability.title}</h3>
              <p class="text-sm leading-6 text-muted mt-3">{capability.description}</p>
              <p class="text-xs font-semibold text-primary mt-4">{capability.detail}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
