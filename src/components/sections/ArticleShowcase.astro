---
// src/components/sections/ArticleShowcase.astro

interface Article {
  category: string;
  title: string;
  excerpt: string;
  readTime: string;
  date: string;
  url: string;
}

// Curated static fallback articles (used when API is not configured or offline)
const fallbackArticles: Article[] = [
  {
    category: "AI & Technology",
    title: "The Rise of Agentic Workflows in Digital Publishing",
    excerpt: "How autonomous AI agents are transitioning from simple text generators to active, context-aware editorial collaborators.",
    readTime: "5 min read",
    date: "June 10, 2026",
    url: "https://blog.envoyou.com/posts/rise-of-agentic-workflows-digital-publishing"
  },
  {
    category: "Digital Creation",
    title: "Designing for Attention: Aesthetics of Modern Blogs",
    excerpt: "A deep dive into typography, negative space, and subtle micro-interactions that keep readers engaged in a distracted world.",
    readTime: "8 min read",
    date: "June 08, 2026",
    url: "https://blog.envoyou.com/posts/designing-for-attention-aesthetics-modern-blogs"
  },
  {
    category: "Modern Business",
    title: "Monetizing Niches: The Era of Editorial Subscriptions",
    excerpt: "Why broad-scale advertising is declining and how focused, high-value content ecosystems are building sustainable revenue.",
    readTime: "6 min read",
    date: "June 05, 2026",
    url: "https://blog.envoyou.com/posts/monetizing-niches-editorial-subscriptions"
  },
  {
    category: "AI & Systems",
    title: "Behind the Screen: Fine-Tuning LLMs for Brand Voice",
    excerpt: "Practical methodologies for training and prompting LLMs to respect complex editorial styles and guidelines consistently.",
    readTime: "10 min read",
    date: "May 28, 2026",
    url: "https://blog.envoyou.com/posts/fine-tuning-llms-brand-voice"
  },
  {
    category: "Productivity",
    title: "The Editor's Checklist: What AI Can and Cannot Review",
    excerpt: "Defining the boundary between automated structural checks and the irreplaceable human touch in creative copy.",
    readTime: "4 min read",
    date: "May 24, 2026",
    url: "https://blog.envoyou.com/posts/editors-checklist-what-ai-cannot-review"
  },
  {
    category: "Future of Web",
    title: "Decentralized Feeds and the Return of RSS Architecture",
    excerpt: "How open protocol distribution is challenging algorithmic timelines and giving power back to content creators.",
    readTime: "7 min read",
    date: "May 19, 2026",
    url: "https://blog.envoyou.com/posts/decentralized-feeds-rss-architecture"
  }
];

// Read API and Blog URLs from Vercel/Env variables
const blogApiUrl = import.meta.env.BLOG_API_URL;
const blogBaseUrl = import.meta.env.BLOG_URL || 'https://blog.envoyou.com';
let articles: Article[] = fallbackArticles;

if (blogApiUrl) {
  try {
    const res = await fetch(`${blogApiUrl}/posts?limit=6`);
    if (res.ok) {
      const json = await res.json();
      const apiPosts = json.data || [];
      if (apiPosts.length > 0) {
        articles = apiPosts.map((post: any) => {
          // Parse category (handles both categories array and category object/string)
          let categoryName = "Insights";
          if (post.categories && post.categories.length > 0) {
            categoryName = post.categories[0].name || "Insights";
          } else if (post.category) {
            categoryName = typeof post.category === 'object' ? (post.category.name || "Insights") : post.category;
          }

          // Format date
          let formattedDate = "Recently";
          const rawDate = post.published_at || post.created_at || post.date;
          if (rawDate) {
            formattedDate = new Date(rawDate).toLocaleDateString('en-US', {
              day: '2-digit',
              month: 'long',
              year: 'numeric'
            });
          }

          return {
            category: categoryName,
            title: post.title || "Untitled Article",
            excerpt: post.excerpt || post.summary || post.description || "",
            readTime: post.reading_time ? `${post.reading_time} min read` : "5 min read",
            date: formattedDate,
            url: `${blogBaseUrl}/posts/${post.slug || ""}`
          };
        });
      }
    }
  } catch (err) {
    console.warn("Failed to fetch dynamic articles from BLOG_API_URL. Falling back to static data.", err);
  }
}
---

<section id="articles" class="relative overflow-hidden py-20 border-b border-border/50">
  <!-- Top glow backdrop decorative elements -->
  <div class="absolute top-0 left-1/4 w-[500px] h-[500px] rounded-full bg-gradient-to-br from-primary/5 via-accent/3 to-transparent blur-3xl pointer-events-none -translate-y-1/2"></div>
  
  <div class="max-w-7xl mx-auto px-6 text-center mb-16 relative z-10">
    <div class="section-label mx-auto">Latest Articles</div>
    <h2 class="section-title">Read our latest articles</h2>
    <p class="section-subtitle mx-auto text-center">
      Insights on AI, technology, digital creation, and modern business — written for curious builders and readers.
    </p>
  </div>

  <!-- Marquee Container -->
  <div class="marquee-container relative flex overflow-hidden select-none w-full py-4">
    <!-- Fade overlays on left/right for a premium gradient fading effect -->
    <div class="absolute top-0 bottom-0 left-0 w-24 sm:w-32 bg-gradient-to-r from-[var(--color-bg)] to-transparent z-15 pointer-events-none"></div>
    <div class="absolute top-0 bottom-0 right-0 w-24 sm:w-32 bg-gradient-to-l from-[var(--color-bg)] to-transparent z-15 pointer-events-none"></div>

    <!-- First Marquee Content Track -->
    <div class="marquee-content flex shrink-0 gap-6 min-w-full animate-marquee pr-6">
      {articles.map((article) => (
        <a 
          href={article.url}
          target="_blank"
          rel="noopener noreferrer"
          class="card group/card relative flex flex-col justify-between w-[320px] sm:w-[380px] md:w-[400px] h-[280px] p-6 sm:p-8 text-left no-underline"
        >
          <!-- Custom Dynamic Brand Glow -->
          <div class="absolute inset-0 bg-gradient-to-br from-primary/5 dark:from-primary/10 via-transparent to-transparent opacity-0 group-hover/card:opacity-100 transition-opacity duration-500 pointer-events-none" />
          
          <div class="relative z-10">
            <!-- Top Row: Category (Unified Brand Style) and Read Time -->
            <div class="flex items-center justify-between mb-4">
              <span class="text-[11px] font-bold px-2.5 py-1 rounded-lg border border-primary/15 dark:border-primary/25 text-primary bg-primary/5 dark:bg-primary/10">
                {article.category}
              </span>
              <span class="text-xs text-muted font-mono">{article.readTime}</span>
            </div>
            
            <!-- Title -->
            <h3 class="text-base sm:text-lg font-bold text-text group-hover/card:text-primary transition-colors duration-300 line-clamp-2 leading-snug">
              {article.title}
            </h3>
            
            <!-- Excerpt -->
            <p class="text-xs sm:text-sm text-muted line-clamp-3 mt-2 leading-relaxed">
              {article.excerpt}
            </p>
          </div>
          
          <!-- Bottom Row: Date and Read Link -->
          <div class="relative z-10 flex items-center justify-between mt-6 pt-4 border-t border-border/50">
            <span class="text-xs text-muted font-mono">{article.date}</span>
            
            <!-- Decorative Arrow Link -->
            <span class="text-primary group-hover/card:translate-x-1 transition-transform duration-300 flex items-center gap-1 text-xs font-semibold">
              Read
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- Duplicated Marquee Content Track for Infinite loop -->
    <div class="marquee-content flex shrink-0 gap-6 min-w-full animate-marquee pr-6" aria-hidden="true">
      {articles.map((article) => (
        <a 
          href={article.url}
          target="_blank"
          rel="noopener noreferrer"
          class="card group/card relative flex flex-col justify-between w-[320px] sm:w-[380px] md:w-[400px] h-[280px] p-6 sm:p-8 text-left no-underline"
        >
          <!-- Custom Dynamic Brand Glow -->
          <div class="absolute inset-0 bg-gradient-to-br from-primary/5 dark:from-primary/10 via-transparent to-transparent opacity-0 group-hover/card:opacity-100 transition-opacity duration-500 pointer-events-none" />
          
          <div class="relative z-10">
            <!-- Top Row: Category (Unified Brand Style) and Read Time -->
            <div class="flex items-center justify-between mb-4">
              <span class="text-[11px] font-bold px-2.5 py-1 rounded-lg border border-primary/15 dark:border-primary/25 text-primary bg-primary/5 dark:bg-primary/10">
                {article.category}
              </span>
              <span class="text-xs text-muted font-mono">{article.readTime}</span>
            </div>
            
            <!-- Title -->
            <h3 class="text-base sm:text-lg font-bold text-text group-hover/card:text-primary transition-colors duration-300 line-clamp-2 leading-snug">
              {article.title}
            </h3>
            
            <!-- Excerpt -->
            <p class="text-xs sm:text-sm text-muted line-clamp-3 mt-2 leading-relaxed">
              {article.excerpt}
            </p>
          </div>
          
          <!-- Bottom Row: Date and Read Link -->
          <div class="relative z-10 flex items-center justify-between mt-6 pt-4 border-t border-border/50">
            <span class="text-xs text-muted font-mono">{article.date}</span>
            
            <!-- Decorative Arrow Link -->
            <span class="text-primary group-hover/card:translate-x-1 transition-transform duration-300 flex items-center gap-1 text-xs font-semibold">
              Read
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  /* CSS Marquee Animation */
  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-100%);
    }
  }

  .animate-marquee {
    animation: marquee 50s linear infinite;
  }

  /* Pause marquee when hovered */
  .marquee-container:hover .animate-marquee {
    animation-play-state: paused;
  }

  /* Dark mode specific overlay visibility adjustments */
  .dark .z-15 {
    mix-blend-mode: plus-lighter;
  }
</style>
