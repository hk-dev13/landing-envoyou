---
const comparisons = [
  {
    label: "Draft refinement",
    without: "Editors move between prompts, documents, and manual checklists.",
    with: "Draft, editorial profile, and revision context stay in one workspace.",
  },
  {
    label: "Claims and sources",
    without: "Unsupported or altered claims can survive until the final review.",
    with: "Source-sensitive feedback is surfaced before the draft can be exported.",
  },
  {
    label: "Publication package",
    without: "Title, slug, excerpt, metadata, and handoff are prepared separately.",
    with: "The final draft and its SEO fields are prepared as one controlled package.",
  },
];

---

<section id="comparison" class="bg-surface-soft border-y border-border" data-scroll-section>
  <div class="section">
    <div class="max-w-3xl mb-12">
      <div class="section-label">A controlled workflow</div>
      <h2 class="section-title">Replace fragmented handoffs with one editorial path.</h2>
      <p class="section-subtitle">
        EAI keeps the source draft, editorial decisions, SEO fields, and final readiness verdict attached to the same article.
      </p>
    </div>

    <div class="overflow-hidden rounded-3xl border border-border bg-surface">
      <div class="hidden md:grid grid-cols-[0.7fr_1fr_1fr] border-b border-border bg-surface-soft text-xs font-bold uppercase tracking-wider">
        <div class="p-5 text-muted md:flex bg-primary/5 md:items-center">Work</div>
        <div class="p-5 text-muted border-l border-border bg-primary/5 md:flex md:items-center">Without EAI</div>
        <div class="p-5 text-primary border-l border-border bg-primary/5 md:flex md:items-center">With EAI</div>
      </div>
      {comparisons.map((item) => (
  <article class="grid grid-cols-1 md:grid-cols-[0.7fr_1fr_1fr] border-b border-border last:border-b-0">

    <h3 class="p-5 font-bold text-text md:flex md:items-center">
      {item.label}
    </h3>

    <div class="p-5 md:border-l border-border bg-surface-soft md:flex md:items-center">
      <div>
        <p class="md:hidden text-[10px] font-bold uppercase tracking-wider text-muted mb-2">
          Without EAI
        </p>
        <p class="text-sm leading-6 text-muted">
          {item.without}
        </p>
      </div>
    </div>

    <div class="p-5 md:border-l border-border bg-primary/5 md:flex md:items-center">
      <div>
        <p class="md:hidden text-[10px] font-bold uppercase tracking-wider text-primary mb-2">
          With EAI
        </p>
        <p class="text-sm leading-6 text-text">
          {item.with}
        </p>
      </div>
    </div>

  </article>
))}
    </div>
  </div>
</section>

<section id="quality-gate" data-scroll-section>
  <div class="section">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div>
        <div class="section-label">Final Quality Gate</div>
        <h2 class="section-title">Know what is ready—and what still needs an editor.</h2>
        <p class="section-subtitle">
          EAI combines structured AI review with deterministic checks for source fidelity and publication requirements. It does not silently treat every generated draft as publishable.
        </p>
        <ul class="mt-8 space-y-4 text-sm">
          <li class="flex gap-3">
            <span class="mt-1.5 h-2 w-2 rounded-full bg-success shrink-0"></span>
            <span><strong class="text-text">Ready</strong><span class="text-muted"> — required checks pass and CMS export can proceed.</span></span>
          </li>
          <li class="flex gap-3">
            <span class="mt-1.5 h-2 w-2 rounded-full bg-amber-500 shrink-0"></span>
            <span><strong class="text-text">Needs review</strong><span class="text-muted"> — feedback remains, or the automated review needs human confirmation.</span></span>
          </li>
          <li class="flex gap-3">
            <span class="mt-1.5 h-2 w-2 rounded-full bg-rose-500 shrink-0"></span>
            <span><strong class="text-text">Blocked</strong><span class="text-muted"> — a critical issue prevents export until it is resolved.</span></span>
          </li>
        </ul>
      </div>

      <div class="card p-7 md:p-9">
        <div class="flex items-center justify-between gap-4 pb-5 border-b border-border">
          <div>
            <p class="text-[10px] font-bold uppercase tracking-wider text-muted">Publication readiness</p>
            <p class="font-bold text-text mt-1">Needs review</p>
          </div>
          <span class="rounded-full border border-amber-500/25 bg-amber-500/10 px-3 py-1 text-xs font-bold text-amber-600 dark:text-amber-400">
            2 items
          </span>
        </div>
        <div class="py-5 border-b border-border">
          <p class="text-xs font-bold text-text">Participant and revenue figures</p>
          <p class="text-xs leading-5 text-muted mt-2">The figures are preserved from the source draft, but no supporting reference is attached.</p>
        </div>
        <div class="py-5">
          <p class="text-xs font-bold text-text">Publication metadata</p>
          <p class="text-xs leading-5 text-muted mt-2">Title, slug, excerpt, meta title, meta description, tags, and cover-image guidance are checked as one package.</p>
        </div>
        <div class="rounded-xl bg-surface-soft border border-border px-4 py-3 text-xs font-semibold text-muted">
          Export stays unavailable until the readiness verdict is Ready.
        </div>
      </div>
    </div>
  </div>
</section>
