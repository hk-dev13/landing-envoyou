---
import stats from '../../data/stats.json';

// Get dynamically loaded stats with fallbacks
const totalDrafts = stats.totalDrafts || 17;
const readyRate = stats.readyRate || 43;
const monthlyReaders = stats.monthlyReaders || "2.4K";
const systemUptime = stats.systemUptime || "100%";
const dateRange = stats.dateRange || "13 May 2026 - 12 June 2026";

const blogStats = stats.blog || {
  publishedArticles: 25,
  views30Days: "2.8K",
  categoriesCount: 4,
  topCategory: "Bisnis & Teknologi",
  topArticleViews: 150,
  avgReadingTime: 5
};

const eaiStats = stats.eai || {
  cmsExportSuccess: "100%",
  brandVoiceAlignment: "82.0%",
  seoCompletionRate: "88.0%",
  avgAiCostPerArticle: "$0.017",
  pricingVersion: "2026-06-12",
  draftsThisMonth: 12,
  avgProcessTimeMins: 1.8,
  finishedDrafts: 15
};
---

<section id="analytics" class="bg-surface-soft overflow-hidden">
  <div class="section">
    <!-- Header -->
    <div class="text-center mb-12">
      <div class="section-label mx-auto">Public Analytics</div>
      <h2 class="section-title">Ecosystem Performance.</h2>
      <p class="section-subtitle mx-auto text-center">
        Real-time metrics tracking content operations, readership engagement, and editorial intelligence efficiency.
      </p>
      <p class="text-center text-xs font-semibold text-muted mt-2 tracking-wide font-mono">
        Reporting Period: {dateRange}
      </p>
    </div>

    <!-- Interactive Card Slider Container -->
    <div class="max-w-3xl mx-auto">
      
      <!-- Custom Toggle Tabs -->
      <div class="flex justify-center mb-8">
        <div class="relative inline-flex p-1 rounded-2xl bg-surface border border-border shadow-sm">
          <!-- Sliding Indicator Pill -->
          <div 
            id="slider-pill" 
            class="absolute top-1 bottom-1 left-1 w-[calc(50%-4px)] rounded-xl bg-surface-soft border border-border shadow-sm transition-transform duration-300 ease-out"
            style="transform: translateX(0%);"
          ></div>
          
          <button
            id="toggle-blog"
            class="relative z-10 px-6 py-2.5 rounded-xl text-sm font-bold transition-colors duration-200 cursor-pointer text-primary"
          >
            Blog Analytics
          </button>
          <button
            id="toggle-eai"
            class="relative z-10 px-6 py-2.5 rounded-xl text-sm font-bold transition-colors duration-200 cursor-pointer text-muted"
          >
            EAI Analytics
          </button>
        </div>
      </div>

      <!-- Slider Viewport -->
      <div class="relative group">
        <!-- Navigation Buttons -->
        <button 
          id="btn-prev" 
          class="absolute -left-16 top-1/2 -translate-y-1/2 hidden md:flex w-10 h-10 rounded-full border border-border bg-surface text-muted hover:text-text hover:shadow-md items-center justify-center transition-all duration-200 cursor-pointer z-20"
          aria-label="Previous card"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path d="M15 19l-7-7 7-7"/>
          </svg>
        </button>
        <button 
          id="btn-next" 
          class="absolute -right-16 top-1/2 -translate-y-1/2 hidden md:flex w-10 h-10 rounded-full border border-border bg-surface text-muted hover:text-text hover:shadow-md items-center justify-center transition-all duration-200 cursor-pointer z-20"
          aria-label="Next card"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path d="M9 5l7 7-7 7"/>
          </svg>
        </button>

        <!-- Cards Scroll Container -->
        <div 
          id="cards-container" 
          class="flex overflow-x-auto snap-x snap-mandatory scroll-smooth scrollbar-none gap-6 pt-6 pb-12 px-8 -mt-6 -mb-10 -mx-8"
        >
          <!-- CARD 1: BLOG ANALYTICS -->
          <div class="w-full shrink-0 snap-center">
            <div class="card p-8 min-h-[380px] relative overflow-hidden bg-surface">
              <!-- Glow -->
              <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-transparent pointer-events-none"></div>
              
              <div class="relative">
                <!-- Card Header -->
                <div class="flex items-center justify-between mb-6 pb-4 border-b border-border">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center">
                      <svg class="w-5 h-5" viewBox="0 0 512 512" fill="currentColor">
                        <path d="M223.2 24.5c-44.7 6.8-85.4 25-119.2 53.3-14.5 12.1-40 40-37.3 40.9.5.2 39.1-6.7 85.8-15.2 46.8-8.6 87.3-16 90-16.5 2.8-.5 18.7-3.4 35.5-6.5s32.5-6 35-6.4c30.6-5.4 68.7-12.6 69.4-13.2 1.2-1-16.6-11.3-30.4-17.5-17.8-8.1-35.3-13.5-57-17.6-13.9-2.6-57.6-3.4-71.8-1.3M430 108.1c-3.1 6.4-9.8 13.2-16.3 16.3-4.1 2-26.2 6.3-106.7 21.1-139.4 25.4-159.8 29.2-172.5 31.5-6 1.2-32.3 6-58.4 10.8l-47.5 8.7-1.3 5c-2.7 10.8-5.4 29.6-6 42.9l-.6 13.8 2.9-.6c1.6-.3 12.3-2.2 23.9-4.1 44.2-7.5 91.9-15.6 114-19.4 12.7-2.2 36.3-6.2 52.5-9s40.1-6.8 53-9c20.7-3.6 56.5-9.5 62.8-10.5 1.2-.2 4.5.1 7.4.6 19.6 3.6 32.3 22.8 27.4 41.6-1.9 7.4-4.9 12.4-10.6 17.6-6.8 6.1-10.6 7.5-30 10.6-5.1.8-34.2 5.8-96.5 16.4-40.2 6.9-94.6 16.2-132.5 22.6-48.8 8.3-63.2 10.9-63.6 11.2-.4.4 4.8 15.1 8.1 22.8 7.4 17.5 19 37.3 21.4 36.6.9-.3 3.2-.7 5.1-1.1 5.5-.8 53.8-9.2 148-25.6 35.8-6.2 47.9-8 52.6-7.6 12.2.9 23 8.4 28.3 19.7 2.2 4.7 2.6 6.9 2.6 14.5 0 8.4-.2 9.5-3.4 15.3-1.9 3.5-5.3 7.9-7.5 9.9-7.5 6.5-9.5 7.1-54.6 14.8-8.5 1.5-20.2 3.5-26 4.5s-16.1 2.8-23 4-17.2 3-23 4c-5.8 1.1-17.8 3.1-26.8 4.6-8.9 1.5-16.2 3-16.2 3.4 0 1.2 19.3 13.4 30.3 19.1 25.3 13.1 52.5 21.4 81.7 24.9 19.8 2.4 53.7.8 74.3-3.5 75.9-15.8 141-70.4 169.5-142.5 18.5-46.6 21.7-95.6 9.6-145-7.9-31.9-25.4-66.3-47-92.1l-3.1-3.8z"/>
                      </svg>
                    </div>
                    <div>
                      <h3 class="text-lg font-bold text-text">Blog Envoyou</h3>
                      <p class="text-xs text-muted">Audience & content statistics</p>
                    </div>
                  </div>
                  <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-emerald-700 dark:text-emerald-400 bg-emerald-100 dark:bg-emerald-900/40 px-3 py-1 rounded-full border border-emerald-300/60 dark:border-emerald-700/50">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                    Live GA4
                  </span>
                </div>

                <!-- Metrics Table -->
                <div class="max-h-[260px] overflow-y-auto pr-1 space-y-4 scrollbar-thin">
                  {[
                    { label: "Published Articles", value: blogStats.publishedArticles, desc: "Total live articles on blog.envoyou.com", icon: "<path d='M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253'></path>" },
                    { label: "Views (30 Days)", value: blogStats.views30Days, desc: "Aggregated article pageviews over 30 days", icon: "<path d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'></path><path d='M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z'></path>" },
                    { label: "Unique Readers", value: monthlyReaders, desc: "Unique visitors tracked via Google Analytics", icon: "<path d='M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2'></path><circle cx='9' cy='7' r='4'></circle><path d='M23 21v-2a4 4 0 00-3-3.87'></path><path d='M16 3.13a4 4 0 010 7.75'></path>" },
                    { label: "Categories", value: blogStats.categoriesCount, desc: "Active content categories on the blog", icon: "<rect x='3' y='3' width='7' height='7' rx='1'></rect><rect x='14' y='3' width='7' height='7' rx='1'></rect><rect x='14' y='14' width='7' height='7' rx='1'></rect><rect x='3' y='14' width='7' height='7' rx='1'></rect>" },
                    { label: "Top Category", value: blogStats.topCategory || "Teknologi & AI", desc: "Category with highest publication volume", icon: "<path d='M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z'></path><line x1='7' y1='7' x2='7.01' y2='7'></line>" },
                    { label: "Top Article Views", value: `${blogStats.topArticleViews || 150} views`, desc: "Total pageviews of the most popular article", icon: "<polygon points='12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2'></polygon>" },
                    { label: "Average Read Time", value: `${blogStats.avgReadingTime || 5} min`, desc: "Average article reading time of published posts", icon: "<circle cx='12' cy='12' r='10'></circle><polyline points='12 6 12 12 16 14'></polyline>" }
                  ].map((row) => (
                    <div class="flex items-center justify-between py-3 border-b border-border last:border-0 hover:bg-surface-soft/30 px-2 rounded-lg transition-colors duration-150">
                      <div class="flex items-center gap-3 max-w-[70%] min-w-0">
                        <div class="w-8 h-8 shrink-0 rounded-lg bg-surface-soft flex items-center justify-center text-muted">
                          <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <Fragment set:html={row.icon} />
                          </svg>
                        </div>
                        <div class="min-w-0">
                          <p class="text-sm font-semibold text-text truncate">{row.label}</p>
                          <p class="text-[10px] text-muted truncate">{row.desc}</p>
                        </div>
                      </div>
                      <p class="text-sm font-extrabold text-primary font-mono text-right truncate max-w-[30%] ml-2" title={String(row.value)}>{row.value}</p>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <!-- CARD 2: EAI ANALYTICS -->
          <div class="w-full shrink-0 snap-center">
            <div class="card p-8 min-h-[380px] relative overflow-hidden bg-surface">
              <!-- Glow -->
              <div class="absolute inset-0 bg-gradient-to-br from-accent/5 via-transparent to-transparent pointer-events-none"></div>
              
              <div class="relative">
                <!-- Card Header -->
                <div class="flex items-center justify-between mb-6 pb-4 border-b border-border">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-accent/10 text-accent flex items-center justify-center">
                      <svg class="w-5 h-5" viewBox="0 0 512 512" fill="currentColor">
                        <path d="M68.1 88.5c-6.3 14.9-10.2 28.3-12 41-.9 6.1-.7 7.4 1.6 13.9 11.8 32.7 41.9 64.8 86.1 91.3 12.4 7.5 45.1 23.7 45.9 22.9.4-.3.2-.6-.3-.6-1.5 0-22.9-12.5-30.3-17.7-54.7-38.5-84.1-87.7-87-145.7l-.6-13.1z"/>
                        <path d="M52.5 151.3c-1.3 9.8.1 37.2 2.3 46.7 5.4 23.1 15.6 44.4 31.5 66 9.3 12.6 34.4 37.4 48.7 48.2 42.9 32.3 97.4 56.2 159.6 70.2 8.9 2 16.9 3.6 17.8 3.6s1.5.3 1.3.8c-.3.4-14.8 10.4-32.2 22.2l-31.7 21.5 55.7.3 55.6.2 32.7-22.1c43.8-29.5 89.6-60.6 95.7-64.8l4.9-3.4-2.4-1.6c-2.6-1.7-78.7-53.2-111.5-75.5l-20-13.6-55.9.2-55.9.3 34.6 23.4c19.1 12.8 34.7 23.4 34.7 23.6 0 .9-41.4-7.1-59.3-11.6-99.5-25-173.3-71.8-199.2-126.4-2.3-5-4.7-10.1-5.2-11.5-.9-2.2-1.1-1.9-1.8 3.3"/>
                      </svg>
                    </div>
                    <div>
                      <h3 class="text-lg font-bold text-text">EAI Editorial Workspace</h3>
                      <p class="text-xs text-muted">Editorial Intelligence & AI Pipeline metrics</p>
                    </div>
                  </div>
                  <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-emerald-700 dark:text-emerald-400 bg-emerald-100 dark:bg-emerald-900/40 px-3 py-1 rounded-full border border-emerald-300/60 dark:border-emerald-700/50">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                    Verified
                  </span>
                </div>

                <!-- Metrics Table -->
                <div class="max-h-[260px] overflow-y-auto pr-1 space-y-4 scrollbar-thin">
                  {[
                    { label: "CMS Export Success", value: eaiStats.cmsExportSuccess, desc: "Successfully exported articles to Vercel/CMS", icon: "<path d='M8.684 10.742l5.053 5.053L21 8M4 16.5L12 21l8-4.5M4 12l8 4.5 8-4.5'></path>" },
                    { label: "Brand Voice Alignment", value: eaiStats.brandVoiceAlignment, desc: "Accuracy rating on style and voice compliance", icon: "<path d='M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 100-6 3 3 0 000 6z'></path>" },
                    { label: "SEO Completion Rate", value: eaiStats.seoCompletionRate, desc: "Articles with meta details verified by EAI", icon: "<circle cx='12' cy='12' r='10'></circle><path d='M22 22l-6-6'></path>" },
                    { label: "Draft processed / month", value: `${eaiStats.draftsThisMonth || 0} drafts`, desc: "Count of processed drafts in the current calendar month", icon: "<rect x='3' y='4' width='18' height='16' rx='2' ry='2'></rect><line x1='16' y1='2' x2='16' y2='6'></line><line x1='8' y1='2' x2='8' y2='6'></line><line x1='3' y1='10' x2='21' y2='10'></line>" },
                    { label: "Avg. process time (mins)", value: `${eaiStats.avgProcessTimeMins || '0.0'} min`, desc: "Average AI processing duration per run", icon: "<circle cx='12' cy='12' r='10'></circle><polyline points='12 6 12 12 16 14'></polyline>" },
                    { label: "Draft finished/polished", value: `${eaiStats.finishedDrafts || 0} drafts`, desc: "Total completed or refined/polished drafts count", icon: "<path d='M22 11.08V12a10 10 0 1 1-5.93-9.14'></path><polyline points='22 4 12 14.01 9 11.01'></polyline>" }
                  ].map((row) => (
                    <div class="flex items-center justify-between py-3 border-b border-border last:border-0 hover:bg-surface-soft/30 px-2 rounded-lg transition-colors duration-150">
                      <div class="flex items-center gap-3 max-w-[70%] min-w-0">
                        <div class="w-8 h-8 shrink-0 rounded-lg bg-surface-soft flex items-center justify-center text-muted">
                          <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <Fragment set:html={row.icon} />
                          </svg>
                        </div>
                        <div class="min-w-0">
                          <p class="text-sm font-semibold text-text truncate">{row.label}</p>
                          <p class="text-[10px] text-muted truncate">{row.desc}</p>
                        </div>
                      </div>
                      <p class="text-sm font-extrabold text-accent font-mono text-right truncate max-w-[30%] ml-2" title={String(row.value)}>{row.value}</p>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Slider Page Indicator Dots -->
        <div class="flex justify-center gap-2 mt-6">
          <button id="dot-0" class="w-2.5 h-2.5 rounded-full bg-primary transition-all duration-300 cursor-pointer" aria-label="Go to Blog stats"></button>
          <button id="dot-1" class="w-2.5 h-2.5 rounded-full bg-border transition-all duration-300 cursor-pointer" aria-label="Go to EAI stats"></button>
        </div>

      </div>
    </div>

    <!-- Data source footer -->
    <p class="text-center text-xs text-muted mt-8">
      Data is dynamically updated. Real-time unique readers are fetched live from GA4.
      <a href="https://blog.envoyou.com" target="_blank" class="text-primary hover:underline ml-1">Read the Blog →</a>
    </p>
  </div>
</section>

<script>
  const container = document.getElementById("cards-container");
  const tabBlog = document.getElementById("toggle-blog");
  const tabEai = document.getElementById("toggle-eai");
  const pill = document.getElementById("slider-pill");
  const btnPrev = document.getElementById("btn-prev");
  const btnNext = document.getElementById("btn-next");
  const dot0 = document.getElementById("dot-0");
  const dot1 = document.getElementById("dot-1");

  function updateActiveState(index: number) {
    if (index === 0) {
      tabBlog?.classList.add("text-primary");
      tabBlog?.classList.remove("text-muted");
      tabEai?.classList.add("text-muted");
      tabEai?.classList.remove("text-primary");
      if (pill) pill.style.transform = "translateX(0%)";
      
      dot0?.classList.remove("bg-border");
      dot0?.classList.add("bg-primary");
      dot1?.classList.remove("bg-primary");
      dot1?.classList.add("bg-border");
    } else {
      tabEai?.classList.add("text-primary");
      tabEai?.classList.remove("text-muted");
      tabBlog?.classList.add("text-muted");
      tabBlog?.classList.remove("text-primary");
      if (pill) pill.style.transform = "translateX(100%)";
      
      dot0?.classList.remove("bg-primary");
      dot0?.classList.add("bg-border");
      dot1?.classList.remove("bg-border");
      dot1?.classList.add("bg-primary");
    }
  }

  function scrollToCard(index: number) {
    if (!container) return;
    const cards = container.children;
    if (cards[index]) {
      const card = cards[index] as HTMLElement;
      container.scrollTo({
        left: card.offsetLeft - (container.clientWidth - card.clientWidth) / 2,
        behavior: "smooth"
      });
    }
    updateActiveState(index);
  }

  // Click tabs
  tabBlog?.addEventListener("click", () => scrollToCard(0));
  tabEai?.addEventListener("click", () => scrollToCard(1));

  // Click dots
  dot0?.addEventListener("click", () => scrollToCard(0));
  dot1?.addEventListener("click", () => scrollToCard(1));

  // Click nav buttons
  btnPrev?.addEventListener("click", () => scrollToCard(0));
  btnNext?.addEventListener("click", () => scrollToCard(1));

  // Detect scroll and update state dynamically (for swipe)
  container?.addEventListener("scroll", () => {
    const cards = container.children;
    if (cards.length > 1) {
      const card0 = cards[0] as HTMLElement;
      const card1 = cards[1] as HTMLElement;
      const scrollStep = card1.offsetLeft - card0.offsetLeft;
      const index = Math.round(container.scrollLeft / scrollStep);
      updateActiveState(index);
    }
  });

  // Handle window resize to re-align scroll position if necessary
  let resizeTimeout: any;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(() => {
      if (!container) return;
      const cards = container.children;
      if (cards.length > 1) {
        const card0 = cards[0] as HTMLElement;
        const card1 = cards[1] as HTMLElement;
        const scrollStep = card1.offsetLeft - card0.offsetLeft;
        const index = Math.round(container.scrollLeft / scrollStep);
        if (cards[index]) {
          const card = cards[index] as HTMLElement;
          container.scrollLeft = card.offsetLeft - (container.clientWidth - card.clientWidth) / 2;
        }
      }
    }, 100);
  });
</script>

<style>
  /* Custom scrollbar styling to make it very subtle and thin */
  .scrollbar-thin {
    scrollbar-width: thin;
    scrollbar-color: rgba(148, 163, 184, 0.25) transparent;
  }
  .scrollbar-thin::-webkit-scrollbar {
    width: 3px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: rgba(148, 163, 184, 0.25);
    border-radius: 9999px;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb:hover {
    background: rgba(148, 163, 184, 0.45);
  }
</style>
