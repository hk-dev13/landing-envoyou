---
const faqs = [
  {
    question: "What happens after I log in to EAI?",
    answer: "You enter the authenticated EAI onboarding and workspace flow. An eligible new workspace receives 10 trial credits, so you can run the real editorial workflow before purchasing a plan."
  },
  {
    question: "What does EAI produce?",
    answer: "In Publish-ready mode, EAI prepares a refined article plus a publication package: title, slug, excerpt, meta title, meta description, tags, and cover-image guidance. The package is reviewed by the Final Quality Gate before export."
  },
  {
    question: "Does EAI automatically approve AI-written content?",
    answer: "No. The Quality Gate returns <strong>Ready</strong>, <strong>Needs review</strong>, or <strong>Blocked</strong>. Source-fidelity and publication checks can keep export unavailable until critical feedback is resolved."
  },
  {
    question: "How do CMS connections work?",
    answer: "An organization can configure a supported REST CMS connection. EAI encrypts the stored connection secret and exports an approved article as a <strong>draft</strong> for the publisher to review in the CMS. Availability depends on the configured adapter; E‑Blog is Envoyou’s internal implementation."
  },
  {
    question: "How do plans and payments work?",
    answer: "Starter, Pro, and Team are prepaid credit plans with monthly or annual options. Checkout is handled through Midtrans, 11% VAT (PPN) is added to the final checkout amount, and automatic recurring billing is not currently enabled."
  }
];

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer.replace(/<[^>]*>/g, " ").replace(/\s+/g, " ").trim(),
    },
  })),
};
---

<section id="faq" class="bg-surface">
  <div class="section">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      <div class="lg:col-span-4 lg:sticky lg:top-28 h-fit">
        <div class="section-label">FAQ</div>
        <h2 class="section-title text-left">Before you enter the workspace.</h2>
        <p class="section-subtitle text-left mt-4">
          Clear answers about access, output, review controls, CMS export, and payment.
        </p>
        <div class="mt-8">
          <p class="text-xs text-muted font-medium">Need account or billing help?</p>
          <a href="https://eai.envoyou.com/support" class="inline-flex items-center gap-1.5 text-sm font-bold text-primary hover:text-primary-deep transition-colors mt-2">
            Contact EAI Support
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="lg:col-span-8 divide-y divide-border">
        {faqs.map((faq) => (
          <details class="faq-item group py-5 cursor-pointer outline-none">
            <summary class="flex items-center justify-between gap-4 font-bold text-base text-text list-none select-none outline-none">
              <span>{faq.question}</span>
              <span class="faq-icon flex items-center justify-center w-6 h-6 rounded-full border border-border text-muted group-hover:text-text group-hover:border-primary/30 transition-all duration-200 shrink-0">
                <svg class="w-3.5 h-3.5 transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path d="M19 9l-7 7-7-7"/>
                </svg>
              </span>
            </summary>
            <div class="faq-answer mt-4 text-sm text-muted leading-7 pr-8 select-text">
              <Fragment set:html={faq.answer} />
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

<script is:inline type="application/ld+json" set:html={JSON.stringify(faqStructuredData)}></script>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }

  .faq-item[open] .faq-icon {
    border-color: var(--color-primary);
    background-color: var(--color-primary);
    color: #ffffff;
  }

  .faq-answer {
    animation: slideDown 0.25s ease-out forwards;
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
