---
// How EAI Works section — step-by-step flow
const steps = [
  {
    number: "01",
    title: "Add the material",
    description: "Start from a raw draft, a topic, or research notes. Choose the publication mode and working language for the article.",
    icon: `<path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>`,
  },
  {
    number: "02",
    title: "Refine under your rules",
    description: "EAI applies the active editorial profile for brand, audience, tone, structure, source policy, language, and SEO constraints.",
    icon: `<path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>`,
  },
  {
    number: "03",
    title: "Review claims and readiness",
    description: "Inspect the final draft, changes, source-sensitive feedback, and the Ready, Needs review, or Blocked Quality Gate verdict.",
    icon: `<circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>`,
  },
  {
    number: "04",
    title: "Export the full package",
    description: "When the verdict is Ready, export the article and its checked title, slug, excerpt, SEO metadata, tags, and cover guidance as a CMS draft.",
    icon: `<path d="M22 2L11 13"/><path d="M22 2L15 22 11 13 2 9l20-7z"/>`,
  },
];
---

<section id="how-it-works" class="bg-surface" data-scroll-section>
  <div class="section">
    <div class="text-center mb-16">
      <div class="section-label mx-auto">How EAI Works</div>
      <h2 class="section-title">From draft to publication,<br />with clarity and consistency.</h2>
      <p class="section-subtitle mx-auto text-center">
        Every stage carries forward the source material, editorial profile, and publication contract so editors can see what changed and why.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {steps.map((step, i) => (
        <div class="relative group">
          <!-- Connector line (desktop, between cards) -->
          {i < steps.length - 1 && (
            <div class="hidden lg:block absolute top-10 left-full w-6 h-px bg-border z-10 -translate-x-0"></div>
          )}

          <div class="card p-6 h-full">
            <div
              class="absolute inset-0 rounded-[var(--radius-lg)] pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300"
              style="background: radial-gradient(circle at 30% 0%, var(--color-hero-glow) 0%, transparent 60%);"
            ></div>

            <div class="relative">
              <!-- Step number + icon -->
              <div class="flex items-center justify-between mb-5">
                <div class="w-11 h-11 rounded-2xl border border-border bg-surface-soft flex items-center justify-center">
                  <svg class="w-4.5 h-4.5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:1.125rem;height:1.125rem;">
                    <Fragment set:html={step.icon} />
                  </svg>
                </div>
                <span class="text-3xl font-black text-primary select-none">{step.number}</span>
              </div>

              <h3 class="text-base font-bold text-text mb-2">{step.title}</h3>
              <p class="text-sm text-muted leading-6">{step.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-12">
      <a
        href="https://eai.envoyou.com/login"
        id="how-eai-cta"
        data-analytics-event="eai_login_clicked"
        data-analytics-location="homepage_how_it_works"
        class="btn-primary"
      >
        Continue to EAI
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M7 17L17 7M17 7H7M17 7v10"/>
        </svg>
      </a>
    </div>
  </div>
</section>
