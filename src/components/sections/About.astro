---
// About section
---

<section id="about" class="bg-surface-soft">
  <div class="section">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Content -->
      <div>
        <div class="section-label">About Envoyou</div>
        <h2 class="section-title">
          Where editorial quality<br />
          meets AI efficiency.
        </h2>
        <p class="section-subtitle">
          Envoyou was built with a single belief: great content deserves great tools.
        </p>

        <div class="mt-10 space-y-6">
          <!-- Feature points -->
          <div class="flex items-start gap-4">
            <div class="w-9 h-9 shrink-0 rounded-xl border border-border bg-surface flex items-center justify-center mt-0.5">
              <svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-text">Making quality publishing more scalable</h3>
              <p class="text-sm text-muted mt-1 leading-6">We simplify the journey from raw ideas to polished, publication-ready copy by combining human editorial expertise, data analysis, and intelligent automation.</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-9 h-9 shrink-0 rounded-xl border border-border bg-surface flex items-center justify-center mt-0.5">
              <svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-text">Scalable Content Operations</h3>
              <p class="text-sm text-muted mt-1 leading-6">EAI is designed to support high-volume content pipelines as your team expands, ensuring strict consistency and quality control without slowing down production.</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-9 h-9 shrink-0 rounded-xl border border-border bg-surface flex items-center justify-center mt-0.5">
              <svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-text">Building for the Long Term</h3>
              <p class="text-sm text-muted mt-1 leading-6">We are committed to creating modern editorial infrastructure—featuring advanced Quality Gates and seamless CMS exports—to power the future of publishing.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Visual card -->
      <div class="relative">
        <div class="card p-8">
          <div
            class="absolute inset-0 rounded-[var(--radius-lg)] pointer-events-none"
            style="background: radial-gradient(circle at 30% 0%, var(--color-hero-glow) 0%, transparent 50%);"
          ></div>
          <div class="relative">
            <p class="text-xs font-semibold text-primary uppercase tracking-widest mb-6">Ecosystem Loop</p>
            <div class="space-y-4">
              {[
                {
                  name: "Create",
                  tech: "Drafts, ideas, outlines",
                  domain: "EAI Workspace",
                },
                {
                  name: "Refine",
                  tech: "Quality checks, source fidelity, editorial polish",
                  domain: "Editorial Intelligence",
                },
                {
                  name: "Publish",
                  tech: "SEO-ready articles and structured CMS workflow",
                  domain: "CMS Export API",
                },
                {
                  name: "Learn",
                  tech: "Analytics, readiness metrics, content performance",
                  domain: "Feedback Loop",
                },
              ].map((item) => (
                <div class="flex items-center justify-between py-3 border-b border-border last:border-0">
                  <div>
                    <p class="text-sm font-semibold text-text">{item.name}</p>
                    <p class="text-xs text-muted mt-0.5">{item.tech}</p>
                  </div>
                  <span class="text-xs font-mono text-primary bg-surface-soft px-2.5 py-1 rounded-lg border border-border">
                    {item.domain}
                  </span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
