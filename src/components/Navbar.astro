---
// Navbar component with theme toggle and sticky behavior
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-bg/90 backdrop-blur-md border-b border-border"
  data-scrolled="false"
>
  <nav class="max-w-[90rem] mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-1.5 group"
      aria-label="Envoyou Home"
    >
      <div class="w-8 h-8 flex items-center justify-center group-hover:brightness-110 transition-all duration-200">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="25" height="25">
          <g fill="#0b79c2">
            <path d="M222 7.5c-44.3 5.9-84.2 22.3-120.8 49.7-15.1 11.3-36.8 33.4-50.3 51.4-.9 1.2-4.7 1.8 76.6-13.1 87-15.9 105.8-19.4 169-31 31.9-5.9 66-12.1 75.8-13.9 9.8-1.7 17.8-3.6 17.8-4.1-.1-2.6-32.5-19.3-50.2-25.9-12.3-4.5-33.4-10-47.4-12.1-14.9-2.4-55.9-2.9-70.5-1M441.6 96.8c-2.8 6.8-12.7 16.3-19.6 18.9-3 1.1-20.6 4.8-39 8.2-18.4 3.3-45.9 8.3-61 11.1s-48.2 8.9-73.5 13.5C46.3 185.6 11.6 192 11 192.7c-1.1 1.2-4.9 20.4-6.5 32.8-.8 6-1.5 15.9-1.5 21.8v10.9l2.7-.6c1.6-.3 35-6 74.3-12.6 39.3-6.7 80.3-13.6 91-15.5 93.6-16.4 163-27.7 168.1-27.2 8.3.7 16.9 5 22.9 11.3 7.7 8.1 9.5 12.8 9.5 24.9 0 8.8-.3 10.7-2.7 15.7-3.4 7.3-10.4 14.3-17.4 17.5-5.5 2.5-7.7 2.9-97.9 18.3-29.1 4.9-207.5 35.4-225.3 38.4-7.3 1.3-13.5 2.6-13.9 2.9-.8.9 4.8 16.8 10.4 29.1 4.1 9.2 14.5 28.5 17.8 32.9 1.4 2-5.7 3.1 141-22.4 67.2-11.7 76.1-13.1 82.5-12.7 12.8.7 24.4 8.7 30.2 20.7 2.9 5.9 3.2 7.5 3.2 15.1-.1 19-11.3 32.6-30.1 36.5-3.8.8-21.4 3.9-39.3 7s-44.2 7.6-58.5 10.1-35 6-45.9 7.9-20.1 3.6-20.3 3.9c-.9.9 21.7 14.9 34.7 21.5 24.1 12.2 49.8 20.6 76.3 24.8 14.1 2.2 58.4 2.5 71.7.5 21.2-3.3 39.8-8.2 57-14.9 77.7-30.5 135.7-97.7 153.8-178.3 5-22.2 5.7-29.4 5.7-56.5 0-27.3-1.2-37.5-6.5-59.3-8.4-34.4-25.3-69-47.2-96.5-3.8-4.8-7-8.7-7.1-8.7s-1.1 2.1-2.1 4.8"/>
          </g>
        </svg>
      </div>
      <span class="text-lg font-bold tracking-tight text-text">Envoyou</span>
    </a>

    <!-- Center Nav Links -->
    <div class="hidden md:flex items-center gap-1">
      <a href="/#products" class="nav-link">Products</a>
      <a href="/#analytics" class="nav-link">Analytics</a>
      <a href="/#how-it-works" class="nav-link">How It Works</a>
      <a href="/pricing" class="nav-link">Pricing</a>
      <a href="/#faq" class="nav-link">FAQ</a>
      <a href="/about" class="nav-link">About</a>
    </div>

    <!-- Right Actions -->
    <div class="flex items-center gap-3">
      <!-- Theme Toggle -->
      <button
        id="theme-toggle"
        class="w-9 h-9 rounded-full flex items-center justify-center text-muted hover:text-text hover:bg-surface-soft transition-all duration-200"
        aria-label="Toggle theme"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg id="icon-sun" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg id="icon-moon" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- CTA -->
      <a
        href="https://eai.envoyou.com"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-white text-sm font-semibold transition-colors duration-200 shadow-sm"
        style="background-color: var(--color-primary);"
        onmouseover="this.style.backgroundColor='var(--color-primary-deep)'"
        onmouseout="this.style.backgroundColor='var(--color-primary)'"
      >
        Try Demo
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M7 17L17 7M17 7H7M17 7v10"/>
        </svg>
      </a>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden w-9 h-9 rounded-full border border-border bg-surface flex items-center justify-center text-muted"
        aria-label="Open menu"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-border bg-surface/95 backdrop-blur-xl px-6 py-4 space-y-1"
  >
    <a href="/#products" class="mobile-nav-link">Products</a>
    <a href="/#analytics" class="mobile-nav-link">Analytics</a>
    <a href="/#how-it-works" class="mobile-nav-link">How It Works</a>
    <a href="/pricing" class="mobile-nav-link">Pricing</a>
    <a href="/#faq" class="mobile-nav-link">FAQ</a>
    <a href="/about" class="mobile-nav-link font-semibold">About</a>
    <div class="pt-3 border-t border-border flex gap-2">
      <a href="https://eai.envoyou.com" target="_blank" class="flex-1 text-center px-4 py-2 rounded-full bg-primary text-white text-sm font-semibold">
        Try Demo
      </a>
    </div>
  </div>
</header>

<script>
  // Navbar scroll effect
  const navbar = document.getElementById("navbar");
  window.addEventListener("scroll", () => {
    const scrolled = window.scrollY > 20;
    navbar?.setAttribute("data-scrolled", scrolled ? "true" : "false");
  });

  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  mobileMenuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  // Close mobile menu on link click
  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => mobileMenu?.classList.add("hidden"));
  });

  // Theme toggle
  const themeToggle = document.getElementById("theme-toggle");
  const iconSun = document.getElementById("icon-sun");
  const iconMoon = document.getElementById("icon-moon");

  function updateIcons() {
    const isDark = document.documentElement.classList.contains("dark");
    iconSun?.classList.toggle("hidden", !isDark);
    iconMoon?.classList.toggle("hidden", isDark);
  }

  updateIcons();

  themeToggle?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    updateIcons();
  });
</script>

<style>
  #navbar[data-scrolled="true"] {
    background: color-mix(in srgb, var(--color-bg) 92%, transparent);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0 1px 20px rgba(0, 0, 0, 0.06);
  }

  .nav-link {
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-muted);
    transition: color 0.2s, background-color 0.2s;
    text-decoration: none;
  }

  .nav-link:hover {
    color: var(--color-text);
    background-color: color-mix(in srgb, var(--color-surface-soft) 80%, transparent);
  }

  .mobile-nav-link {
    display: block;
    padding: 0.625rem 0.75rem;
    border-radius: 0.75rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-muted);
    transition: color 0.2s, background-color 0.2s;
    text-decoration: none;
  }

  .mobile-nav-link:hover {
    color: var(--color-text);
    background-color: var(--color-surface-soft);
  }
</style>
