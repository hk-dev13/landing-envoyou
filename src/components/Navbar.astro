---
// Navbar component with theme toggle and sticky behavior
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  data-scrolled="false"
>
  <nav class="max-w-screen mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-1.5 group"
      aria-label="Envoyou Home"
    >
      <div class="w-8 h-8 flex items-center justify-center group-hover:brightness-110 transition-all duration-200">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 600" width="25" height="25">
          <g fill="currentColor">
            <path d="M289 66.5V123h22V10h-22zm88.75 11.85C366.4 106.5 357 130.05 356.8 130.8s3.4 2.7 9.5 5.15l9.8 3.9.9-2.35c.5-1.3 9.75-24.3 20.55-51.15C420.3 29.9 418.7 35.3 413 33c-2.45-1-6.8-2.7-9.55-3.8l-5.1-2zM186.5 33.15c-4.95 2.2-9.15 4.15-9.35 4.35-.3.3 42.5 102.05 43.5 103.4.5.65 19.3-7.35 19.35-8.25 0-.45-9.05-22.05-20.15-48C208.8 58.7 199 35.6 198.15 33.25s-1.8-4.2-2.1-4.15-4.6 1.85-9.55 4.05M94.75 95.3c-3.7 3.85-6.75 7.3-6.75 7.6 0 .35 17.75 18.4 39.5 40.1l39.5 39.5 7.75-7.75 7.75-7.75-39.5-39.5c-21.7-21.75-39.95-39.45-40.5-39.35s-4.05 3.3-7.75 7.15M457 127.5 417.5 167l7.75 7.75 7.75 7.75 39.5-39.5c21.75-21.7 39.5-39.75 39.5-40.05 0-.35-3.25-3.85-7.15-7.8-3.95-3.9-7.45-7.15-7.8-7.15-.3 0-18.35 17.75-40.05 39.5m53 71.3c-27.75 11.85-50.65 21.7-50.9 21.85-.6.45 7.35 19.3 8.2 19.35.4 0 23.5-9.7 51.25-21.5 27.75-11.85 51-21.5 51.6-21.5.55 0 .85-.55.55-1.25-5.05-12.3-8.2-18.75-9.1-18.65-.6.05-23.8 9.8-51.6 21.7M34.35 183.65c-.4 1-2.2 5.4-4 9.8-1.85 4.35-3.2 8-3.1 8.1.45.4 102.2 41.3 103.55 41.65.75.2 2.7-3.4 5.15-9.5l3.9-9.8-2.65-1c-1.5-.6-24.5-9.8-51.2-20.55-26.65-10.75-49.05-19.8-49.75-20.05-.65-.3-1.55.35-1.9 1.35M10 300v11h113v-22H10zm279 0v11h301v-22H289zm178.35 57.75c-.35.95-2.15 5.5-3.95 10.05l-3.3 8.3 2.7 1c1.45.55 24.5 9.85 51.2 20.6 26.65 10.75 49.1 19.6 49.8 19.65 1.05.15 9.7-18.25 8.9-18.95-.1-.1-22-9-48.7-19.75-26.65-10.75-50.2-20.25-52.25-21.1-3.55-1.5-3.85-1.5-4.4.2M91.5 377.1c-21.45 9.25-44.15 18.95-50.5 21.55-6.3 2.6-11.6 4.8-11.75 4.85-.25.2 7.7 18.75 8.3 19.35.3.3 102-42.5 103.35-43.5 1.05-.75-7.55-19.3-8.9-19.2-.8.05-19.05 7.7-40.5 16.95m35.75 80.15C105.65 478.85 88 496.75 88 497.1c0 .75 14.15 14.9 14.95 14.9.3 0 18.35-17.75 40.05-39.5l39.45-39.5-7.45-7.5c-4.1-4.1-7.7-7.5-8-7.5-.25 0-18.15 17.65-39.75 39.25M425 425.5l-7.45 7.5L457 472.5c21.7 21.75 39.75 39.5 40.05 39.5.8 0 14.95-14.15 14.95-14.95 0-.7-78.3-79.05-79.05-79.05-.25 0-3.85 3.4-7.95 7.5m-56.25 37.35c-4.8 2-8.75 4.05-8.75 4.5s8.95 21.85 19.9 47.5 20.7 48.65 21.65 51.15c1 2.45 1.85 4.6 1.95 4.75.15.25 18.75-7.7 19.35-8.3.7-.7-43.35-103.4-44.35-103.35-.55.05-4.95 1.7-9.75 3.75M223 462.5c-.5 1.3-9.75 24.3-20.55 51.15-10.8 26.9-19.75 49.45-19.8 50.2-.1 1 18.3 9.55 19 8.8.3-.35 41.25-102.25 41.55-103.45.2-.75-3.4-2.7-9.5-5.15l-9.8-3.9zm66 71V590h22V477h-22z"/>
          </g>
        </svg>
      </div>
      <span class="text-lg font-bold tracking-tight text-text">Envoyou</span>
    </a>

    <!-- Center Nav Links -->
    <div class="hidden md:flex items-center gap-1">
      <a href="/#products" class="nav-link">Products</a>
      <a href="/#analytics" class="nav-link">Analytics</a>
      <a href="/#how-it-works" class="nav-link">How It Works</a>
      <a href="/pricing" class="nav-link">Pricing</a>
      <a href="/#faq" class="nav-link">FAQ</a>
      <a href="/about" class="nav-link">About</a>
    </div>

    <!-- Right Actions -->
    <div class="flex items-center gap-3">
      <!-- Theme Toggle -->
      <button
        id="theme-toggle"
        class="w-9 h-9 rounded-full flex items-center justify-center text-muted hover:text-text hover:bg-surface-soft transition-all duration-200"
        aria-label="Toggle theme"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg id="icon-sun" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg id="icon-moon" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- CTA -->
      <a
        href="#tally-open=ODy5xM&tally-emoji-text=👋&tally-emoji-animation=wave&ref=navbar"
        data-analytics-event="beta_access_clicked"
        data-analytics-location="navbar_desktop"
        class="hidden md:inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-white text-sm font-semibold transition-colors duration-200 shadow-sm"
        style="background-color: var(--color-primary);"
        onmouseover="this.style.backgroundColor='var(--color-primary-deep)'"
        onmouseout="this.style.backgroundColor='var(--color-primary)'"
      >
        Request Access
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M7 17L17 7M17 7H7M17 7v10"/>
        </svg>
      </a>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden w-9 h-9 rounded-full border border-border bg-surface flex items-center justify-center text-muted"
        aria-label="Open menu"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-border bg-surface/95 backdrop-blur-xl px-6 py-4 space-y-1"
  >
    <a href="/#products" class="mobile-nav-link">Products</a>
    <a href="/#analytics" class="mobile-nav-link">Analytics</a>
    <a href="/#how-it-works" class="mobile-nav-link">How It Works</a>
    <a href="/pricing" class="mobile-nav-link">Pricing</a>
    <a href="/#faq" class="mobile-nav-link">FAQ</a>
    <a href="/about" class="mobile-nav-link font-semibold">About</a>
    <div class="pt-3 border-t border-border flex gap-2">
      <a
        href="#tally-open=ODy5xM&tally-emoji-text=👋&tally-emoji-animation=wave&ref=navbar_mobile"
        data-analytics-event="beta_access_clicked"
        data-analytics-location="navbar_mobile"
        class="flex-1 text-center px-4 py-2 rounded-full bg-primary text-white text-sm font-semibold"
      >
        Request Access
      </a>
    </div>
  </div>
</header>

<script>
  // Navbar scroll effect
  const navbar = document.getElementById("navbar");
  function updateScrollState() {
    const scrolled = window.scrollY > 20;
    navbar?.setAttribute("data-scrolled", scrolled ? "true" : "false");
  }
  
  window.addEventListener("scroll", updateScrollState);
  // Run on initial load
  updateScrollState();

  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  mobileMenuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  // Close mobile menu on link click
  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => mobileMenu?.classList.add("hidden"));
  });

  // Theme toggle
  const themeToggle = document.getElementById("theme-toggle");
  const iconSun = document.getElementById("icon-sun");
  const iconMoon = document.getElementById("icon-moon");

  function updateIcons() {
    const isDark = document.documentElement.classList.contains("dark");
    iconSun?.classList.toggle("hidden", !isDark);
    iconMoon?.classList.toggle("hidden", isDark);
  }

  updateIcons();

  themeToggle?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    updateIcons();
  });

  // Trigger navigation on hover with a small delay to prevent accidental triggers
  let hoverTimeout: any;
  document.querySelectorAll(".nav-link").forEach((link) => {
    link.addEventListener("mouseenter", () => {
      const href = link.getAttribute("href");
      if (href) {
        hoverTimeout = setTimeout(() => {
          window.location.href = href;
        }, 250); // 250ms delay
      }
    });

    link.addEventListener("mouseleave", () => {
      clearTimeout(hoverTimeout);
    });
  });
</script>

<style>
  #navbar {
    border-bottom: 1px solid transparent;
  }

  #navbar[data-scrolled="true"] {
    background: color-mix(in srgb, var(--color-bg) 92%, transparent);
    backdrop-filter: blur(20px);
    border-bottom-color: var(--color-border);
    box-shadow: 0 1px 20px rgba(0, 0, 0, 0.06);
  }

  .nav-link {
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-muted);
    transition: color 0.2s, background-color 0.2s;
    text-decoration: none;
  }

  .nav-link:hover {
    color: var(--color-text);
    background-color: color-mix(in srgb, var(--color-surface-soft) 80%, transparent);
  }

  .mobile-nav-link {
    display: block;
    padding: 0.625rem 0.75rem;
    border-radius: 0.75rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-muted);
    transition: color 0.2s, background-color 0.2s;
    text-decoration: none;
  }

  .mobile-nav-link:hover {
    color: var(--color-text);
    background-color: var(--color-surface-soft);
  }
</style>
